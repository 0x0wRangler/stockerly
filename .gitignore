# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Local workspace artifacts (design mockups, scratch notes, etc.) that should
# never be committed to the repo. See .claude/memory/project_design_assets.md
# for the inventory and conventions.
/.local/

# Local research workspace (audits, market studies, technical primers).
# Source material for future issues/sprints; not part of the codebase.
# See .research/README.md for the index.
/.research/

# Ignore bundler config.
/.bundle

# Ignore all environment files (except .env.example).
/.env*
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore SimpleCov coverage output
/coverage

# Ignore key files for decrypting credentials and more.
/config/*.key


/app/assets/builds/*
!/app/assets/builds/.keep

# LLM / AI tool files
.claude/*
!.claude/memory/
.cursor/
.cursorignore
.cursorindexingignore
.cursorrules
.gemini/
.aider*
.copilot/
.github/copilot*
.openai/
.codeium/
.continue/
.windsurf/
