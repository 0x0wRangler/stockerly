<%# Datos y sesión tab — LFPDPPP data export + sign out. es-MX per
    S09 #97, Lumen S11 #146. %>
<div class="space-y-8">
  <section>
    <h3 class="text-base font-semibold tracking-tight text-fg-default">Tus datos</h3>
    <p class="mt-1 text-sm text-fg-subtle mb-4">
      Conforme a la Ley Federal de Protección de Datos Personales en Posesión de los Particulares (LFPDPPP),
      puedes solicitar acceso, rectificación, cancelación u oposición sobre tus datos (derechos ARCO).
      Tiempo de respuesta: 20 días hábiles.
    </p>

    <div class="flex flex-wrap gap-3">
      <%= mail_to Stockerly::SUPPORT_EMAIL, "Solicitar acceso a mis datos",
          subject: "Solicitud ARCO - Acceso a mis datos",
          body: "Solicito copia de los datos personales que Stockerly tiene de mi cuenta (#{current_user.email}).",
          class: "inline-flex items-center gap-2 rounded-lg border border-border-default bg-bg-surface px-4 py-2 text-sm font-semibold text-fg-default hover:bg-bg-muted transition-colors" %>

      <%= mail_to Stockerly::SUPPORT_EMAIL, "Eliminar mi cuenta",
          subject: "Solicitud ARCO - Cancelación de cuenta",
          body: "Solicito la eliminación de mi cuenta (#{current_user.email}) y los datos personales asociados.",
          class: "inline-flex items-center gap-2 rounded-lg border border-negative/40 bg-bg-surface px-4 py-2 text-sm font-semibold text-negative hover:bg-negative-bg transition-colors" %>
    </div>
    <p class="mt-4 text-xs text-fg-subtle">
      Más detalles del procedimiento ARCO en el <%= link_to "Aviso de privacidad", privacy_path, class: "text-primary font-medium hover:underline" %>.
    </p>
  </section>

  <div class="border-t border-border-default"></div>

  <section>
    <h3 class="text-base font-semibold tracking-tight text-fg-default">Sesión</h3>
    <p class="mt-1 text-sm text-fg-subtle mb-4">Cierra tu sesión en este dispositivo.</p>

    <%= button_to logout_path, method: :delete,
        class: "inline-flex items-center gap-2 rounded-lg border border-border-default bg-bg-surface px-4 py-2 text-sm font-semibold text-fg-default hover:bg-bg-muted transition-colors" do %>
      <span class="material-symbols-outlined text-[16px]">logout</span>
      Cerrar sesión
    <% end %>
  </section>
</div>
