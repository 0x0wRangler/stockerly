<%# Seguridad tab — change password. es-MX per S09 #97. %>
<section class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-200 dark:border-slate-800">
  <h3 class="text-lg font-bold mb-1 text-slate-900 dark:text-white">Seguridad</h3>
  <p class="text-sm text-slate-500 dark:text-slate-400 mb-6">Cambia tu contraseña. Las sesiones activas se cerrarán al hacerlo.</p>

  <%= form_with url: change_password_path, method: :patch, class: "space-y-4 max-w-md" do |f| %>
    <div>
      <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Contraseña actual</label>
      <input type="password" name="password_change[current_password]" autocomplete="current-password" required
             class="w-full px-4 py-2.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-sm text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all">
    </div>
    <div>
      <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Nueva contraseña</label>
      <input type="password" name="password_change[password]" autocomplete="new-password" placeholder="Mínimo 8 caracteres" required
             class="w-full px-4 py-2.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-sm text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all">
    </div>
    <div>
      <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Confirmar nueva contraseña</label>
      <input type="password" name="password_change[password_confirmation]" autocomplete="new-password" required
             class="w-full px-4 py-2.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-sm text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all">
    </div>
    <button type="submit" class="px-5 py-2.5 bg-primary text-white text-sm font-semibold rounded-lg hover:bg-primary/90 transition-colors shadow-sm">
      Cambiar contraseña
    </button>
  <% end %>
</section>
