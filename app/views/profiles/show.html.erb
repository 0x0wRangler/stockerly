<%# Profile — user settings only. Watchlist removed per S09 #97 (lives in /market). %>

<%= render "profiles/profile_header", user: current_user %>

<%# Tabbed settings layout — single column, fluid. %>
<div data-controller="tabs">
  <%# Tab buttons %>
  <div class="flex gap-1 mb-6 bg-slate-100 dark:bg-slate-800 rounded-lg p-1 overflow-x-auto">
    <button data-tabs-target="tab" data-action="tabs#switch" class="flex-1 min-w-32 text-xs font-bold py-2 px-4 rounded-md transition-colors">Información</button>
    <button data-tabs-target="tab" data-action="tabs#switch" class="flex-1 min-w-32 text-xs font-bold py-2 px-4 rounded-md transition-colors">Seguridad</button>
    <button data-tabs-target="tab" data-action="tabs#switch" class="flex-1 min-w-32 text-xs font-bold py-2 px-4 rounded-md transition-colors">Preferencias</button>
    <button data-tabs-target="tab" data-action="tabs#switch" class="flex-1 min-w-32 text-xs font-bold py-2 px-4 rounded-md transition-colors">Datos y sesión</button>
  </div>

  <div data-tabs-target="panel">
    <%= render "profiles/information_tab", user: current_user %>
  </div>

  <div data-tabs-target="panel" class="hidden">
    <%= render "profiles/security_tab" %>
  </div>

  <div data-tabs-target="panel" class="hidden">
    <%= render "profiles/preferences_tab", user: current_user %>
  </div>

  <div data-tabs-target="panel" class="hidden">
    <%= render "profiles/data_session_tab" %>
  </div>
</div>
