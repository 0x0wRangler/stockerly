<%# Preferencias tab — theme + currency + 3-channel notifications.
    Theme persists via localStorage (Stimulus + early-paint script in
    application.html.erb head). Currency and per-channel toggles persist
    via PATCH /profile and PATCH /profile/preferences respectively.
    es-MX per S11 #146. %>
<div class="space-y-8">

  <%# Apariencia — theme segmented control. %>
  <section>
    <h3 class="text-base font-semibold tracking-tight text-fg-default">Apariencia y región</h3>
    <p class="mt-1 text-sm text-fg-subtle">
      El tema se guarda en este dispositivo. No afecta otros navegadores.
    </p>

    <div class="mt-4 divide-y divide-border-default">
      <div class="flex items-center gap-4 py-3.5">
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-fg-default">Tema</p>
          <p class="text-xs text-fg-subtle">Claro · Oscuro · Sistema (sigue tu preferencia del sistema operativo)</p>
        </div>
        <div data-controller="theme" data-theme-storage-key-value="stockerly.theme"
             class="inline-flex items-center rounded-lg border border-border-default bg-bg-muted p-1">
          <% [["light", "Claro"], ["dark", "Oscuro"], ["system", "Sistema"]].each do |mode, label| %>
            <button type="button"
                    data-controller-target="option"
                    data-theme-target="option"
                    data-theme-mode="<%= mode %>"
                    data-action="click->theme#select"
                    class="px-3 py-1.5 text-xs font-medium rounded-md text-fg-subtle data-[theme-active=true]:bg-bg-surface data-[theme-active=true]:text-fg-default data-[theme-active=true]:shadow-sm">
              <%= label %>
            </button>
          <% end %>
        </div>
      </div>

      <%# Currency — posts to the dedicated /profile/currency endpoint,
          which only writes the preferred_currency attribute. Avoids the
          hidden-field pattern that risks stale-data overwrites of
          full_name / email when the user has the profile open in
          multiple tabs (Gemini review, #146). %>
      <%= form_with url: update_currency_path, method: :patch, scope: :profile, class: "flex items-center gap-4 py-3.5" do |f| %>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-fg-default">Moneda preferida</p>
          <p class="text-xs text-fg-subtle">Define cómo se muestran tus totales consolidados en el panel.</p>
        </div>
        <div class="inline-flex items-center rounded-lg border border-border-default bg-bg-muted p-1">
          <% ["MXN", "USD"].each do |code| %>
            <% selected = user.preferred_currency == code %>
            <label class="cursor-pointer">
              <%= tag.input type: "radio", name: "profile[preferred_currency]", value: code, checked: selected, class: "sr-only peer" %>
              <span class="block px-3 py-1.5 text-xs font-mono font-semibold rounded-md <%= selected ? 'bg-bg-surface text-fg-default shadow-sm' : 'text-fg-subtle' %>">
                <%= code %>
              </span>
            </label>
          <% end %>
        </div>
        <%= f.submit "Guardar", class: "rounded-lg bg-primary px-3 py-1.5 text-xs font-semibold text-white hover:bg-primary-hover shadow-sm cursor-pointer" %>
      <% end %>

      <%# Timezone — not editable during the beta. %>
      <div class="flex items-center gap-4 py-3.5">
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-fg-default">Zona horaria</p>
          <p class="text-xs text-fg-subtle">No editable durante la beta.</p>
        </div>
        <span class="inline-flex items-center gap-1.5 rounded-md border border-border-default bg-bg-muted px-2.5 py-1.5 text-xs font-mono text-fg-default">
          <span class="material-symbols-outlined text-[14px] text-fg-subtle">schedule</span>
          América/Ciudad de México · CDMX
        </span>
      </div>
    </div>
  </section>

  <%# Notificaciones — 3 channel toggles wired to alert_preferences.
      Backend gap: per-notification-type granularity (matrix) needs a new
      schema; today these 3 channels apply to *all* notification types.
      Flagged in PR body of #146. %>
  <section>
    <h3 class="text-base font-semibold tracking-tight text-fg-default">Notificaciones</h3>
    <p class="mt-1 text-sm text-fg-subtle">
      Actualmente todas las alertas y avisos del sistema comparten estos canales.
      Pronto podrás elegir el canal por tipo de notificación.
    </p>

    <%
      pref = user.alert_preference
      email_on    = pref&.email_digest      != false
      browser_on  = pref&.browser_push      != false
      sms_on      = pref&.sms_notifications == true
    %>

    <div class="mt-4 divide-y divide-border-default">
      <% channels = [
           ["email_digest",      "Avisos por correo",         "Resumen diario + avisos disparados (todas las alertas)", "mail",          email_on],
           ["browser_push",      "Avisos en la app",          "Push del navegador + campana del header",                "notifications", browser_on],
           ["sms_notifications", "Avisos por SMS",            "Solo para alertas críticas (Twilio).",                   "sms",           sms_on]
         ] %>
      <% channels.each do |field, label, sub, icon, on| %>
        <div class="flex items-center gap-4 py-3.5"
             data-controller="toggle"
             data-toggle-url-value="<%= update_preferences_path %>"
             data-toggle-field-value="<%= field %>">
          <span class="size-8 rounded-md bg-bg-muted text-fg-subtle flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-[16px]"><%= icon %></span>
          </span>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-fg-default"><%= label %></p>
            <p class="text-xs text-fg-subtle"><%= sub %></p>
          </div>
          <button type="button" data-action="click->toggle#toggle"
                  aria-label="Activar/desactivar <%= label %>"
                  class="relative inline-flex h-6 w-11 shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors">
            <span data-toggle-target="track" class="pointer-events-none inline-block h-5 w-11 rounded-full transition-colors <%= on ? 'bg-primary' : 'bg-bg-muted' %>"></span>
            <span data-toggle-target="knob" class="pointer-events-none absolute left-0 inline-block h-5 w-5 rounded-full bg-white shadow ring-0 transition-transform <%= on ? 'translate-x-5' : 'translate-x-0' %>"></span>
          </button>
        </div>
      <% end %>
    </div>
  </section>
</div>
