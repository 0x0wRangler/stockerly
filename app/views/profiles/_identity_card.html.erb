<%# IdentityCard sidebar — avatar + name + email + miembro desde +
    plan/role badge. Stacks above the settings panel on mobile via
    grid-cols-1 → grid-cols-12 at md.
    Counts come precomputed from ProfilesController#show via `counts:`
    local — no inline DB queries.
    es-MX per S11 #146. %>
<% initials = user.full_name.to_s.split.map(&:first).join.upcase.presence || user.email[0].upcase %>
<% role_label = user.admin? ? "Administrador" : "Usuario" %>
<% role_icon  = user.admin? ? "shield_person" : "person" %>

<aside class="rounded-2xl border border-border-default bg-bg-surface p-6 shadow-sm">
  <div class="flex flex-col items-center gap-4 text-center">
    <div class="size-20 rounded-2xl bg-primary-muted border-4 border-white dark:border-bg-canvas shadow-xl flex items-center justify-center">
      <span class="text-2xl font-black text-primary"><%= initials %></span>
    </div>
    <div>
      <h2 class="text-xl font-extrabold tracking-tight text-fg-default"><%= user.full_name %></h2>
      <p class="mt-1 text-sm text-fg-subtle"><%= user.email %></p>
      <p class="mt-2 text-xs text-fg-subtle">
        Miembro desde <%= l(user.created_at.to_date, format: "%-d %b %Y") %>
      </p>
    </div>
    <span class="inline-flex items-center gap-1.5 rounded-full border border-primary/25 bg-primary-muted px-3 py-1 text-xs font-semibold text-primary">
      <span class="material-symbols-outlined text-[13px]"><%= role_icon %></span>
      <%= role_label %>
    </span>
  </div>

  <%# Lightweight stats — counts only, no money. %>
  <div class="mt-6 pt-5 border-t border-border-default space-y-3">
    <div class="flex items-center gap-3">
      <span class="size-7 rounded-md bg-bg-muted text-fg-subtle flex items-center justify-center shrink-0">
        <span class="material-symbols-outlined text-[15px]">account_balance_wallet</span>
      </span>
      <span class="text-sm text-fg-default flex-1">Posiciones abiertas</span>
      <span class="font-mono text-sm font-semibold text-fg-default"><%= counts[:open_positions] %></span>
    </div>
    <div class="flex items-center gap-3">
      <span class="size-7 rounded-md bg-bg-muted text-fg-subtle flex items-center justify-center shrink-0">
        <span class="material-symbols-outlined text-[15px]">visibility</span>
      </span>
      <span class="text-sm text-fg-default flex-1">Activos en watchlist</span>
      <span class="font-mono text-sm font-semibold text-fg-default"><%= counts[:watchlist_items] %></span>
    </div>
    <div class="flex items-center gap-3">
      <span class="size-7 rounded-md bg-bg-muted text-fg-subtle flex items-center justify-center shrink-0">
        <span class="material-symbols-outlined text-[15px]">notifications_active</span>
      </span>
      <span class="text-sm text-fg-default flex-1">Alertas activas</span>
      <span class="font-mono text-sm font-semibold text-fg-default"><%= counts[:active_alerts] %></span>
    </div>
  </div>
</aside>
