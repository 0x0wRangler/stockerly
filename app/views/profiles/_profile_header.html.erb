<%# Profile header — avatar + identity. es-MX per S09 #97. %>
<% initials = user.full_name.to_s.split.map(&:first).join.upcase.presence || user.email[0].upcase %>

<div class="flex flex-col md:flex-row items-center md:items-end gap-6 mb-8">
  <%# Avatar with initials %>
  <div class="relative group">
    <div class="size-28 rounded-2xl bg-primary/10 border-4 border-white dark:border-slate-900 shadow-xl flex items-center justify-center">
      <span class="text-3xl font-black text-primary"><%= initials %></span>
    </div>
  </div>

  <%# Name & meta %>
  <div class="flex-1 text-center md:text-left">
    <p class="text-[11px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">Tu perfil</p>
    <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white"><%= user.full_name %></h1>
    <p class="mt-1 text-sm text-slate-500 dark:text-slate-400 flex items-center justify-center md:justify-start gap-2">
      <span class="material-symbols-outlined text-sm">calendar_today</span>
      Miembro desde <%= l(user.created_at.to_date, format: "%B %Y") %>
    </p>
  </div>
</div>
