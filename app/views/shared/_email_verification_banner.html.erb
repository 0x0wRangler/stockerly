<% if current_user && !current_user.email_verified? %>
  <div class="bg-warning/10 dark:bg-warning/20 border-b border-warning/20 dark:border-warning/30">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-3">
      <div class="flex items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-warning-fg dark:text-warning">mail</span>
          <p class="text-sm font-medium text-warning-fg dark:text-warning">
            Please verify your email address.
            We sent a verification link to <strong><%= current_user.email %></strong>.
          </p>
        </div>
        <%= button_to "Resend email", resend_verification_path, method: :post,
            class: "text-sm font-semibold text-warning-fg dark:text-warning hover:underline whitespace-nowrap" %>
      </div>
    </div>
  </div>
<% end %>
