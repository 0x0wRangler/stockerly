<%# Earnings event detail %>
<div class="mx-auto max-w-2xl">
  <div class="mb-6">
    <%= link_to earnings_path, class: "inline-flex items-center gap-1 text-sm font-medium text-slate-500 hover:text-primary transition-colors" do %>
      <span class="material-symbols-outlined text-lg">arrow_back</span>
      Volver al calendario
    <% end %>
  </div>

  <div class="overflow-hidden rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 shadow-sm">
    <%# Header %>
    <div class="border-b border-slate-200 dark:border-slate-800 p-6">
      <div class="flex items-center justify-between gap-4">
        <div class="flex items-center gap-4">
          <%= render "components/asset_badge", asset: @event.asset, size: "lg" %>
          <div>
            <h1 class="text-2xl font-extrabold tracking-tight text-slate-900 dark:text-white"><%= @event.asset.name %></h1>
            <p class="mt-0.5 text-sm text-slate-500"><%= @event.asset.symbol %> · <%= earnings_venue(@event) %></p>
          </div>
        </div>
        <% if @event.beat_miss %>
          <% beat = @event.beat_miss == :beat %>
          <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-sm font-bold <%= beat ? 'bg-emerald-50 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400' : 'bg-rose-50 dark:bg-rose-900/30 text-rose-600 dark:text-rose-400' %>">
            <span class="material-symbols-outlined text-lg"><%= beat ? "trending_up" : "trending_down" %></span>
            <%= beat ? "Superó estimado" : "Por debajo" %> · <%= @event.eps_surprise_percent %>%
          </span>
        <% else %>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-100 px-3 py-1.5 text-sm font-bold text-slate-500 dark:bg-slate-800">
            <span class="material-symbols-outlined text-lg">schedule</span>
            Por reportar
          </span>
        <% end %>
      </div>
    </div>

    <%# Details grid %>
    <div class="grid grid-cols-2 gap-px bg-slate-200 dark:bg-slate-800">
      <div class="bg-white dark:bg-slate-900 p-5">
        <p class="mb-1 text-xs font-bold uppercase tracking-wider text-slate-500">Fecha de reporte</p>
        <p class="text-lg font-bold text-slate-900 dark:text-white"><%= earnings_date_header(@event.report_date) %></p>
        <% unless @event.confirmed? %>
          <p class="mt-1 text-xs font-semibold text-amber-600 dark:text-amber-400">Fecha por confirmar</p>
        <% end %>
      </div>
      <div class="bg-white dark:bg-slate-900 p-5">
        <p class="mb-1 text-xs font-bold uppercase tracking-wider text-slate-500">Horario</p>
        <p class="flex items-center gap-1.5 text-lg font-bold capitalize text-slate-900 dark:text-white">
          <span class="material-symbols-outlined text-lg text-slate-400"><%= @event.before_market_open? ? "wb_sunny" : "nights_stay" %></span>
          <%= earnings_timing_label(@event) %>
        </p>
      </div>
      <div class="bg-white dark:bg-slate-900 p-5">
        <p class="mb-1 text-xs font-bold uppercase tracking-wider text-slate-500">EPS estimado</p>
        <p class="font-mono text-lg font-bold text-slate-900 dark:text-white">
          <%= @event.estimated_eps ? "#{earnings_currency(@event)} #{sprintf('%.2f', @event.estimated_eps)}" : "—" %>
        </p>
      </div>
      <div class="bg-white dark:bg-slate-900 p-5">
        <p class="mb-1 text-xs font-bold uppercase tracking-wider text-slate-500">EPS reportado</p>
        <% if @event.actual_eps %>
          <p class="font-mono text-lg font-bold <%= @event.beat_miss == :beat ? 'text-emerald-600 dark:text-emerald-400' : 'text-rose-600 dark:text-rose-400' %>">
            <%= earnings_currency(@event) %> <%= sprintf("%.2f", @event.actual_eps) %>
          </p>
        <% else %>
          <p class="text-lg font-bold text-slate-400">Pendiente</p>
        <% end %>
      </div>
    </div>

    <%# Footer: link to asset detail %>
    <div class="border-t border-slate-200 dark:border-slate-800 p-5">
      <%= link_to market_asset_path(@event.asset.symbol), class: "inline-flex items-center gap-2 text-sm font-bold text-primary hover:text-primary/80 transition-colors" do %>
        <span class="material-symbols-outlined text-lg">show_chart</span>
        Ver detalle de <%= @event.asset.symbol %>
        <span class="material-symbols-outlined text-lg">arrow_forward</span>
      <% end %>
    </div>
  </div>
</div>
