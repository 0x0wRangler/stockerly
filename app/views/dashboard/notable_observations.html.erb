<%= turbo_frame_tag "dashboard_notable_observations" do %>
  <% if @observations.any? %>
    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-5 shadow-sm">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
          <span class="material-symbols-outlined text-lg">insights</span>
          <p class="text-sm font-semibold tracking-tight uppercase">Notable Observations</p>
        </div>
      </div>
      <ul class="space-y-3">
        <% @observations.each do |observation| %>
          <li class="flex items-start gap-3 pb-3 border-b border-slate-100 dark:border-slate-800 last:border-0 last:pb-0">
            <span class="material-symbols-outlined text-base text-slate-400">trending_up</span>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-slate-900 dark:text-white truncate">
                <%= link_to observation.asset.symbol, market_asset_path(observation.asset.symbol), class: "hover:underline" %>
                <%= observation.phrase %>
              </p>
              <p class="text-xs text-slate-500 dark:text-slate-400">
                <%= observation.asset.name %> — <%= time_ago_in_words(observation.observed_at) %> ago
              </p>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
<% end %>
