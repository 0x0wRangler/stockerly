<%# Tus posiciones — Stockerly-2.0 dashboard pass (S11 #143).
    Mockup: .local/design-mockups/Stockerly-2.0/dashboard/Dashboard.jsx · WatchlistTable.
    Reads @watchlist_items preloaded by Trading::UseCases::AssembleDashboard. %>
<section class="rounded-2xl border border-border-default bg-bg-surface shadow-sm overflow-hidden">
  <header class="flex flex-wrap items-center gap-3 px-5 py-4">
    <h2 class="text-base font-semibold tracking-tight text-fg-default">Tus posiciones</h2>
    <% if @watchlist_items.present? %>
      <span class="inline-flex items-center rounded-md bg-primary-muted px-2 py-0.5 font-mono text-[11px] font-medium text-primary">
        <%= pluralize(@watchlist_items.size, "activo") %>
      </span>
    <% end %>
    <div class="ml-auto flex items-center gap-2">
      <%= link_to market_path, class: "inline-flex items-center gap-1 rounded-md border border-border-default bg-bg-surface px-2.5 py-1 text-xs font-medium text-fg-subtle hover:text-fg-default hover:bg-bg-muted transition-colors" do %>
        <span class="material-symbols-outlined text-[14px]">add</span>
        Agregar
      <% end %>
    </div>
  </header>

  <% if @watchlist_items.present? %>
    <div class="overflow-x-auto">
      <table class="w-full text-left">
        <thead>
          <tr class="bg-bg-muted text-[10.5px] font-semibold uppercase tracking-widest text-fg-subtle">
            <th class="border-y border-border-default px-4 py-2.5 font-semibold">Ticker</th>
            <th class="border-y border-border-default px-4 py-2.5 font-semibold">Empresa</th>
            <th class="border-y border-border-default px-4 py-2.5 font-semibold">Tipo</th>
            <th class="border-y border-border-default px-4 py-2.5 text-right font-semibold">Precio actual</th>
            <th class="border-y border-border-default px-4 py-2.5 text-right font-semibold">Δ día</th>
            <th class="border-y border-border-default px-4 py-2.5 text-center font-semibold">7d</th>
          </tr>
        </thead>
        <tbody>
          <% @watchlist_items.each do |item| %>
            <% asset = item.asset %>
            <% change = asset.change_percent_24h || 0 %>
            <% positive = change >= 0 %>
            <%= turbo_stream_from "asset_#{asset.id}" %>
            <% cache ["watchlist_row_v2", asset.id, asset.updated_at, asset.price_updated_at], expires_in: 10.minutes do %>
              <tr class="border-t border-border-default hover:bg-bg-muted/60 transition-colors">
                <td class="px-4 py-3">
                  <%= link_to market_asset_path(asset.symbol),
                              class: "font-mono text-sm font-semibold #{positive ? 'text-primary' : 'text-fg-default'} hover:underline" do %>
                    <%= asset.symbol %>
                  <% end %>
                </td>
                <td class="px-4 py-3 max-w-[220px]">
                  <%= link_to market_asset_path(asset.symbol), class: "block group" do %>
                    <div class="truncate text-sm text-fg-default group-hover:text-primary transition-colors">
                      <%= asset.name %>
                    </div>
                    <div class="mt-0.5 text-[11px] text-fg-subtle truncate">
                      <%= asset.exchange.presence || asset.sector.presence || "—" %>
                    </div>
                  <% end %>
                </td>
                <td class="px-4 py-3">
                  <span class="inline-flex items-center rounded-md bg-bg-muted px-2 py-0.5 text-[11px] font-medium text-fg-subtle">
                    <%= asset_type_label_es(asset) %>
                  </span>
                </td>
                <td id="asset_price_<%= asset.id %>" class="px-4 py-3 text-right"
                    data-controller="price-flash" data-price-flash-value="<%= asset.current_price %>">
                  <span class="font-mono text-sm text-fg-default"><%= asset_currency_price(asset) %></span>
                  <div class="mt-0.5"><%= render "components/data_status", asset: asset, market_open: market_open_for(asset) %></div>
                </td>
                <td class="px-4 py-3 text-right">
                  <span class="font-mono text-sm font-medium <%= positive ? 'text-positive' : 'text-negative' %>">
                    <%= positive ? "+" : "−" %><%= number_to_percentage(change.abs, precision: 2) %>
                  </span>
                </td>
                <td class="px-4 py-3">
                  <div class="mx-auto flex justify-center">
                    <% real_heights = sparkline_heights(asset) %>
                    <%= render "components/sparkline", direction: positive ? :up : :down, heights: real_heights %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="px-5 py-10 text-center text-sm text-fg-subtle">
      Aún no sigues ningún activo.
      <%= link_to "Explorar el mercado", market_path, class: "font-semibold text-primary hover:underline" %>.
    </div>
  <% end %>
</section>
