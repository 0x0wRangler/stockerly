<%# Tendencias hoy — Stockerly-2.0 dashboard pass (S11 #143).
    Mockup: .local/design-mockups/Stockerly-2.0/dashboard/Dashboard.jsx · TrendingPanel.
    Compact ranked list (1..N) of trending tickers with delta % only.
    Reads @trending (MarketData::Queries::TrendingAssets) via DashboardController#trending. %>
<% cache "trending_today_v2", expires_in: 1.hour do %>
  <section class="rounded-2xl border border-border-default bg-bg-surface shadow-sm overflow-hidden">
    <header class="flex items-baseline gap-2 px-4 py-3.5">
      <h3 class="text-[15px] font-semibold tracking-tight text-fg-default">Tendencias hoy</h3>
      <span class="text-[11px] text-fg-subtle">Mercado · ordenado por |Δ|</span>
    </header>

    <% if @trending.present? %>
      <ul class="px-4 pb-3">
        <% @trending.each_with_index do |asset, idx| %>
          <% change = asset.change_percent_24h || 0 %>
          <% positive = change >= 0 %>
          <li class="flex items-center gap-3 py-2.5 <%= 'border-t border-border-default' if idx.positive? %>">
            <span class="w-6 shrink-0 font-mono text-[11px] text-fg-subtle"><%= idx + 1 %></span>
            <%= link_to market_asset_path(asset.symbol),
                        class: "font-mono text-sm font-semibold #{positive ? 'text-primary' : 'text-fg-default'} hover:underline" do %>
              <%= asset.symbol %>
            <% end %>
            <span class="ml-auto font-mono text-sm font-medium <%= positive ? 'text-positive' : 'text-negative' %>">
              <%= positive ? "+" : "−" %><%= number_to_percentage(change.abs, precision: 2) %>
            </span>
          </li>
        <% end %>
      </ul>
      <div class="border-t border-border-default bg-bg-muted px-4 py-2.5">
        <%= link_to "Descubrir más activos", market_path,
              class: "block text-center text-[11.5px] font-medium text-fg-subtle hover:text-fg-default transition-colors" %>
      </div>
    <% else %>
      <div class="px-5 py-8 text-center text-sm text-fg-subtle">
        Sin movimientos relevantes ahora mismo.
      </div>
    <% end %>
  </section>
<% end %>
