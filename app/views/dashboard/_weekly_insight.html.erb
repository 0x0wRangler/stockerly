<%# Lectura semanal — Stockerly-2.0 dashboard pass (S11 #143).
    Mockup: .local/design-mockups/Stockerly-2.0/dashboard/Dashboard.jsx · WeeklyPanel.
    Calm sidebar card. Summary text comes from
    Trading::Domain::WeeklyInsightCalculator via @weekly_insight. %>
<% cache ["weekly_insight_v2", current_user.id, Date.current], expires_in: 1.day do %>
  <section class="rounded-2xl border border-border-default bg-bg-surface shadow-sm overflow-hidden">
    <header class="px-4 py-3.5">
      <h3 class="text-[11px] font-bold uppercase tracking-[0.14em] text-fg-subtle">Lectura semanal</h3>
    </header>

    <div class="px-4 pb-4">
      <% if @weekly_insight && @weekly_insight[:has_data] %>
        <p class="text-[13px] leading-relaxed text-fg-subtle whitespace-pre-line">
          <%= @weekly_insight[:summary_text] %>
        </p>
      <% else %>
        <p class="text-[13px] text-fg-subtle">
          Agrega posiciones a tu portafolio para ver tu lectura semanal.
        </p>
      <% end %>
    </div>

    <footer class="border-t border-border-default bg-bg-muted px-4 py-2.5 text-[11px] text-fg-subtle">
      Generado los domingos · Última actualización:
      <%= short_date_upper_es(Date.current.beginning_of_week(:sunday)) %>
    </footer>
  </section>
<% end %>
