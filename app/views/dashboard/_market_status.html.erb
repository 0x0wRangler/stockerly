<%# Estado del mercado — Stockerly-2.0 dashboard pass (S11 #143).
    Mockup: .local/design-mockups/Stockerly-2.0/dashboard/Dashboard.jsx · MarketsPanel.
    Renders one row per index showing the open/closed dot, the index name +
    last value, and the day Δ. The mockup uses three venues (BMV / NYSE /
    NASDAQ); we surface every index seeded in @indices so the panel scales
    with whatever MarketData::Queries::MajorIndices returns. %>
<section class="rounded-2xl border border-border-default bg-bg-surface shadow-sm overflow-hidden">
  <header class="px-4 py-3.5">
    <h3 class="text-[15px] font-semibold tracking-tight text-fg-default">Estado del mercado</h3>
  </header>

  <% if @indices.present? %>
    <ul class="px-4 pb-3">
      <% @indices.each_with_index do |idx, i| %>
        <%
          val      = idx.value&.to_f
          chg      = idx.change_percent&.to_f || 0
          positive = chg >= 0
          is_open  = idx.is_open
        %>
        <li class="grid grid-cols-[1fr_auto] items-center gap-3 py-2.5 <%= 'border-t border-border-default' if i.positive? %>">
          <div class="min-w-0">
            <div class="flex items-center gap-2">
              <span class="text-sm font-medium text-fg-default truncate"><%= idx.name.presence || idx.symbol %></span>
              <span class="inline-flex items-center gap-1 rounded bg-bg-muted px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider <%= is_open ? 'text-positive' : 'text-fg-subtle' %>">
                <span class="h-1.5 w-1.5 rounded-full <%= is_open ? 'bg-positive animate-pulse' : 'bg-fg-subtle' %>"></span>
                <%= is_open ? "Abierto" : "Cerrado" %>
              </span>
            </div>
            <p class="mt-1 truncate font-mono text-[11px] text-fg-subtle">
              <%= idx.symbol %><% if val %> · <%= number_with_delimiter(val.round(2)) %><% end %>
            </p>
          </div>
          <div class="text-right shrink-0">
            <span class="font-mono text-sm font-medium <%= positive ? 'text-positive' : 'text-negative' %>">
              <%= positive ? "+" : "−" %><%= number_to_percentage(chg.abs, precision: 2) %>
            </span>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="px-5 py-8 text-center text-sm text-fg-subtle">
      Sin datos de mercados ahora mismo.
    </div>
  <% end %>
</section>
