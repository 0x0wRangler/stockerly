<%# Usage: render "dashboard/fear_greed_card", reading: @fear_greed[:crypto], label: "Crypto", history: @fear_greed[:crypto_history] %>
<% reading ||= nil %>
<% label ||= "Index" %>
<% history ||= [] %>

<article class="bg-bg-surface rounded-xl border border-border-default p-5 shadow-sm">
  <header class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
      <span class="material-symbols-outlined text-lg">psychology</span>
      <h3 class="text-sm font-semibold tracking-tight uppercase"><%= label %> Fear & Greed</h3>
    </div>
  </header>

  <% if reading.present? %>
    <%
      val = reading.value
      tier = case val
             when 0..24  then 1
             when 25..44 then 2
             when 45..55 then 3
             when 56..74 then 4
             else 5
             end
      sentiment = "var(--color-sentiment-#{tier})"
    %>
    <div class="flex items-center justify-between mb-4">
      <div class="flex flex-col items-start">
        <span class="text-4xl font-bold leading-[1.1]" style="color: <%= sentiment %>"><%= val %></span>
        <span class="text-xs font-bold tracking-wide uppercase text-slate-500 dark:text-slate-400 mt-1"><%= reading.classification %></span>
      </div>

      <%# Inline sparkline — 30-day history %>
      <% if history.size >= 2 %>
        <%
          spark_w = 80
          spark_h = 28
          step_x = spark_w.to_f / (history.size - 1)
          spark_pts = history.each_with_index.map { |(_, v), i|
            y = spark_h - (v.to_f / 100 * spark_h)
            "#{(i * step_x).round(1)},#{y.round(1)}"
          }.join(" ")
        %>
        <svg viewBox="0 0 <%= spark_w %> <%= spark_h %>" class="w-20 h-7 flex-shrink-0" preserveAspectRatio="none" aria-label="<%= label %> Fear & Greed 30-day trend">
          <polyline points="<%= spark_pts %>"
                    fill="none" stroke="<%= sentiment %>" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round"/>
        </svg>
      <% end %>
    </div>

    <%# Gauge %>
    <div class="relative mb-4">
      <div class="flex justify-between mb-1.5 px-0.5">
        <span class="text-[10px] font-bold uppercase" style="color: var(--color-sentiment-1)">Fear</span>
        <span class="text-[10px] font-bold uppercase" style="color: var(--color-sentiment-5)">Greed</span>
      </div>
      <div class="relative h-2 w-full bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
        <div class="h-full w-full opacity-30" style="background: linear-gradient(90deg, var(--color-sentiment-1) 0%, var(--color-sentiment-2) 25%, var(--color-sentiment-3) 50%, var(--color-sentiment-4) 75%, var(--color-sentiment-5) 100%)"></div>
        <div class="absolute top-0 left-0 h-full rounded-full" style="width: <%= val %>%; background-color: <%= sentiment %>" role="progressbar" aria-valuenow="<%= val %>" aria-valuemin="0" aria-valuemax="100"></div>
      </div>
      <div class="absolute -bottom-1.5 transform -translate-x-1/2 w-3 h-3 bg-bg-surface border-2 rounded-full shadow-sm z-10" style="left: <%= val %>%; border-color: <%= sentiment %>"></div>
    </div>

    <%# Sub-indicators (stocks only — CNN F&G components) %>
    <% if reading.component_data.present? %>
      <%
        indicator_labels = {
          "market_momentum_sp500" => "Market Momentum",
          "stock_price_strength" => "Price Strength",
          "stock_price_breadth" => "Price Breadth",
          "put_call_options" => "Put/Call Options",
          "market_volatility_vix" => "Market Volatility",
          "junk_bond_demand" => "Junk Bond Demand",
          "safe_haven_demand" => "Safe Haven Demand"
        }
      %>
      <div data-controller="reveal" class="mb-3">
        <button data-action="reveal#toggle" class="w-full flex items-center justify-center gap-1 py-1.5 text-[10px] font-bold uppercase tracking-wider text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors">
          <span class="material-symbols-outlined text-xs">expand_more</span>
          Sub-Indicators
        </button>
        <div data-reveal-target="content" class="hidden space-y-2 mt-2">
          <% reading.component_data.each do |key, data| %>
            <%
              score = data["score"]&.to_f || 0
              ind_tier = case score.round
                         when 0..24  then 1
                         when 25..44 then 2
                         when 45..55 then 3
                         when 56..74 then 4
                         else 5
                         end
            %>
            <div class="flex items-center gap-2">
              <span class="text-[10px] text-slate-500 dark:text-slate-400 w-28 truncate"><%= indicator_labels[key] || key.titleize %></span>
              <div class="flex-1 h-1.5 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                <div class="h-full rounded-full" style="width: <%= score.clamp(0, 100).round %>%; background-color: var(--color-sentiment-<%= ind_tier %>)"></div>
              </div>
              <span class="text-[10px] font-bold text-slate-600 dark:text-slate-300 w-8 text-right"><%= score.round %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <footer class="flex justify-between items-center pt-2 border-t border-slate-100 dark:border-slate-800">
      <div class="flex items-center gap-1">
        <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background-color: <%= sentiment %>"></span>
        <span class="text-[10px] font-medium text-slate-400 uppercase"><%= reading.stale? ? "Stale" : "Live" %></span>
      </div>
      <time class="text-[11px] text-slate-400 dark:text-slate-500 flex items-center gap-1">
        <span class="material-symbols-outlined text-xs">schedule</span>
        Updated <%= time_ago_in_words(reading.fetched_at) %> ago
      </time>
    </footer>
  <% else %>
    <div class="flex flex-col items-center py-6 text-slate-400 dark:text-slate-500">
      <span class="material-symbols-outlined text-3xl mb-2">hourglass_empty</span>
      <p class="text-xs font-medium">No data yet</p>
    </div>
  <% end %>
</article>
