<!DOCTYPE html>
<html lang="es-MX">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <title>Stockerly</title>
  </head>
  <body style="margin:0; padding:0; background:#f8fafc; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color:#0f172a;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#f8fafc;">
      <tr>
        <td align="center" style="padding:32px 16px;">
          <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="560" style="max-width:560px; width:100%; background:#ffffff; border:1px solid #e2e8f0; border-radius:12px; overflow:hidden;">
            <%# Logo header band — absolute URL so it renders in every mail client. %>
            <tr>
              <td style="padding:28px 32px 0;">
                <a href="<%= root_url %>" style="display:inline-block; text-decoration:none;">
                  <%= image_tag image_url("logo_light.svg"), alt: "Stockerly",
                        height: "32", style: "display:block; height:32px; width:auto;" %>
                </a>
              </td>
            </tr>
            <%# Body %>
            <tr>
              <td style="padding:24px 32px 32px;">
                <%= yield %>
              </td>
            </tr>
            <%# Footer band %>
            <tr>
              <td style="padding:20px 32px; background:#f8fafc; border-top:1px solid #e2e8f0; font-size:11px; color:#94a3b8;">
                Stockerly · Open Source Market Intelligence · Solo informativo, no es asesoría financiera.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
