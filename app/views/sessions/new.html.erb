<% content_for(:title, "Iniciar sesión | Stockerly") %>

<main class="grow flex items-center justify-center p-4 py-12">
  <div class="w-full max-w-md bg-white dark:bg-slate-900 rounded-xl overflow-hidden shadow-xl p-8 lg:p-10">
    <%# Toggle Switch %>
    <div class="flex p-1 bg-slate-100 dark:bg-slate-800 rounded-lg mb-8">
      <div class="flex-1 py-2 text-sm font-semibold rounded-md bg-white dark:bg-slate-700 shadow-sm text-slate-900 dark:text-white text-center">Iniciar sesión</div>
      <%= link_to "Crear cuenta", register_path, class: "flex-1 py-2 text-sm font-semibold rounded-md text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors text-center" %>
    </div>

    <div class="space-y-6">
      <div class="text-center md:text-left">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Inicia sesión</h2>
        <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">Accede a tu cuenta de Stockerly.</p>
      </div>

      <%# Error Messages %>
      <% if flash[:alert] && flash[:alert] != "Please sign in to continue." && flash[:alert] != "Inicia sesión para continuar." %>
        <div class="p-3 rounded-lg bg-rose-50 dark:bg-rose-900/20 border border-rose-200 dark:border-rose-800 text-sm text-rose-700 dark:text-rose-400 flex items-center gap-2">
          <span class="material-symbols-outlined text-lg">error</span>
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%# Login Form %>
      <%= form_with url: login_path, method: :post, class: "space-y-4" do |f| %>
        <div>
          <label for="email" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Correo electrónico</label>
          <input type="email" id="email" name="email" autocomplete="email" placeholder="tu.correo@ejemplo.com" value="<%= params[:email] %>" required class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all">
        </div>
        <div>
          <label for="password" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Contraseña</label>
          <input type="password" id="password" name="password" autocomplete="current-password" placeholder="&#9679;&#9679;&#9679;&#9679;&#9679;&#9679;&#9679;&#9679;" required class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all">
        </div>
        <div class="flex items-center">
          <input type="checkbox" id="remember" name="remember" value="1" class="w-4 h-4 text-primary border-slate-300 rounded focus:ring-primary">
          <label for="remember" class="ml-2 text-sm text-slate-600 dark:text-slate-400">Recuérdame por 30 días</label>
        </div>
        <button type="submit" class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-3 px-4 rounded-lg transition-colors shadow-md shadow-primary/20 flex items-center justify-center gap-2">
          <span>Iniciar sesión</span>
          <span class="material-symbols-outlined text-lg">arrow_forward</span>
        </button>
      <% end %>

      <p class="text-center text-sm text-slate-500 dark:text-slate-400 mt-4">
        ¿Olvidaste tu contraseña?
        <%= link_to "Recupérala.", forgot_password_path, class: "text-primary font-medium hover:underline" %>
      </p>

      <p class="text-center text-xs text-slate-500 dark:text-slate-400 mt-2">
        Al iniciar sesión aceptas nuestros
        <%= link_to "Términos del servicio", terms_path, class: "underline hover:text-slate-800 dark:hover:text-slate-200" %> y nuestro
        <%= link_to "Aviso de privacidad", privacy_path, class: "underline hover:text-slate-800 dark:hover:text-slate-200" %>.
      </p>
    </div>
  </div>
</main>
