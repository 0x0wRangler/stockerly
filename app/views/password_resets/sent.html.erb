<% content_for(:title, "Revisa tu correo | Stockerly") %>
<%# State 2 — forgot-sent confirmation. Privacy-preserving copy: same
    message regardless of whether the email exists in the system. The
    `Identity::UseCases::RequestPasswordReset` use case is responsible
    for the silent no-op on unknown emails. Per S11 #147. %>

<main class="grow flex items-center justify-center p-4 py-12">
  <div class="w-full max-w-md bg-bg-surface rounded-2xl shadow-xl border border-border-default p-8 lg:p-10">
    <div class="flex flex-col items-center text-center space-y-3">
      <div class="size-14 rounded-2xl bg-primary-muted text-primary flex items-center justify-center mb-2">
        <span class="material-symbols-outlined text-3xl">mark_email_read</span>
      </div>
      <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-fg-subtle">Recuperación</p>
      <h2 class="text-2xl font-extrabold tracking-tight text-fg-default">Revisa tu correo</h2>
      <p class="text-sm text-fg-subtle max-w-sm">
        Si el correo está registrado, te enviamos un enlace para restablecer tu contraseña.
        Revisa tu bandeja en los próximos minutos.
      </p>
      <p class="text-xs text-fg-subtle max-w-sm">
        Recuerda revisar la carpeta de spam si no aparece.
      </p>
    </div>

    <%# Inert "what next" strip — expiration hint. %>
    <div class="mt-6 rounded-lg border border-border-default bg-bg-muted px-4 py-3 flex items-center gap-3 text-xs text-fg-subtle">
      <span class="material-symbols-outlined text-[16px]">schedule</span>
      <span>
        El enlace expira en
        <span class="font-mono font-semibold text-fg-default"><%= duration_in_words_es(User::PASSWORD_RESET_EXPIRES_IN) %></span>.
      </span>
    </div>

    <p class="mt-6 text-center text-sm text-fg-subtle">
      ¿No recibiste el correo?
      <%= link_to "Intentar de nuevo.", forgot_password_path, class: "text-primary font-medium hover:underline" %>
    </p>
  </div>
</main>
