<% content_for(:title, "Restablecer contraseña | Stockerly") %>
<%# State 3 — reset form. Token comes from the URL; we resolve the user
    via `find_user_by_token` in the controller. Per S11 #147. %>

<main class="grow flex items-center justify-center p-4 py-12">
  <div class="w-full max-w-md bg-bg-surface rounded-2xl shadow-xl border border-border-default p-8 lg:p-10">
    <div class="space-y-6">
      <div class="text-center md:text-left">
        <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-fg-subtle">Restablecer contraseña</p>
        <h2 class="mt-2 text-2xl font-extrabold tracking-tight text-fg-default">Nueva contraseña</h2>
        <p class="mt-1 text-sm text-fg-subtle">Elige una contraseña que recuerdes y no compartas con nadie.</p>
      </div>

      <%# Error Messages — surfaced when the password contract fails %>
      <% if @user&.errors&.any? %>
        <div class="rounded-lg border border-negative/30 bg-negative-bg/40 p-3 text-sm text-negative-fg">
          <div class="flex items-center gap-2 mb-1">
            <span class="material-symbols-outlined text-[18px]">error</span>
            <span class="font-medium">Por favor revisa los campos marcados:</span>
          </div>
          <ul class="list-disc pl-9 space-y-0.5">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with url: reset_password_path(token: params[:token]), method: :patch, class: "space-y-4" do |f| %>
        <%# Nueva contraseña %>
        <div data-controller="password-visibility">
          <label for="password" class="block text-sm font-medium text-fg-default mb-1.5">Nueva contraseña</label>
          <div class="relative">
            <input type="password" id="password" name="password" autocomplete="new-password" required
                   placeholder="••••••••"
                   data-password-visibility-target="input"
                   class="w-full px-4 py-3 rounded-lg border border-border-default bg-bg-surface text-fg-default focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all pr-12">
            <button type="button" data-action="click->password-visibility#toggle"
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-fg-subtle hover:text-fg-default">
              <span class="material-symbols-outlined" data-password-visibility-target="icon">visibility</span>
            </button>
          </div>
          <p class="mt-1.5 text-xs text-fg-subtle">Mínimo 8 caracteres.</p>
        </div>

        <%# Confirmar nueva contraseña %>
        <div data-controller="password-visibility">
          <label for="password_confirmation" class="block text-sm font-medium text-fg-default mb-1.5">Confirmar nueva contraseña</label>
          <div class="relative">
            <input type="password" id="password_confirmation" name="password_confirmation" autocomplete="new-password" required
                   placeholder="••••••••"
                   data-password-visibility-target="input"
                   class="w-full px-4 py-3 rounded-lg border border-border-default bg-bg-surface text-fg-default focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all pr-12">
            <button type="button" data-action="click->password-visibility#toggle"
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-fg-subtle hover:text-fg-default">
              <span class="material-symbols-outlined" data-password-visibility-target="icon">visibility</span>
            </button>
          </div>
        </div>

        <button type="submit"
                class="w-full bg-primary hover:bg-primary-hover text-white font-semibold py-3 px-4 rounded-lg transition-colors shadow-md shadow-primary/20 flex items-center justify-center gap-2">
          Actualizar contraseña
          <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
        </button>
      <% end %>

      <p class="text-center text-xs text-fg-subtle">
        Después de actualizarla volverás a iniciar sesión.
      </p>
    </div>
  </div>
</main>
