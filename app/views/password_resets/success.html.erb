<% content_for(:title, "Contraseña actualizada | Stockerly") %>
<%# State 5 — reset-success. Per S11 #147. %>

<main class="grow flex items-center justify-center p-4 py-12">
  <div class="w-full max-w-md bg-bg-surface rounded-2xl shadow-xl border border-border-default p-8 lg:p-10">
    <div class="flex flex-col items-center text-center space-y-3">
      <div class="size-14 rounded-2xl bg-positive-bg text-positive flex items-center justify-center mb-2">
        <span class="material-symbols-outlined text-3xl">check_circle</span>
      </div>
      <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-fg-subtle">Restablecer contraseña</p>
      <h2 class="text-2xl font-extrabold tracking-tight text-fg-default">Contraseña actualizada</h2>
      <p class="text-sm text-fg-subtle max-w-sm">Inicia sesión con tu nueva contraseña.</p>
    </div>

    <%= link_to login_path,
          class: "mt-6 w-full bg-primary hover:bg-primary-hover text-white font-semibold py-3 px-4 rounded-lg transition-colors shadow-md shadow-primary/20 flex items-center justify-center gap-2" do %>
      Ir a iniciar sesión
      <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
    <% end %>
  </div>
</main>
