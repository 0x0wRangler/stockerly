<% content_for(:title, "Recuperar contraseña | Stockerly") %>
<%# State 1 — forgot form. Centered card pattern matching /login and
    /register, per S11 #147. %>

<main class="grow flex items-center justify-center p-4 py-12">
  <div class="w-full max-w-md bg-bg-surface rounded-2xl shadow-sm border border-border-default p-8 lg:p-10">
    <div class="space-y-6">
      <div class="text-center md:text-left">
        <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-fg-subtle">Recuperación</p>
        <h2 class="mt-2 text-2xl font-extrabold tracking-tight text-fg-default">Recupera tu acceso</h2>
        <p class="mt-1 text-sm text-fg-subtle">
          Te enviaremos un enlace al correo registrado para que puedas crear una nueva contraseña.
        </p>
      </div>

      <%# Alert from rate-limit or other constraints. The "sent" state
          lives on its own template — never via a flash here. %>
      <% if flash[:alert].present? %>
        <div class="rounded-lg border border-negative/30 bg-negative-bg/40 p-3 text-sm text-negative-fg flex items-center gap-2">
          <span class="material-symbols-outlined text-[18px]">error</span>
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with url: forgot_password_path, method: :post, class: "space-y-4" do |f| %>
        <div>
          <label for="email" class="block text-sm font-medium text-fg-default mb-1.5">Correo electrónico</label>
          <input type="email" id="email" name="email" autocomplete="email" required
                 placeholder="tu.correo@ejemplo.com"
                 value="<%= params[:email] %>"
                 class="w-full px-4 py-3 rounded-lg border border-border-default bg-bg-surface text-fg-default focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all">
        </div>
        <button type="submit"
                class="w-full bg-primary hover:bg-primary-hover text-white font-semibold py-3 px-4 rounded-lg transition-colors shadow-md shadow-primary/20 flex items-center justify-center gap-2">
          Enviar enlace
          <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
        </button>
      <% end %>

      <p class="text-center text-sm text-fg-subtle">
        ¿Recordaste tu contraseña?
        <%= link_to "Inicia sesión.", login_path, class: "text-primary font-medium hover:underline" %>
      </p>
    </div>
  </div>
</main>
