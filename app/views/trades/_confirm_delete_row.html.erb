<%# Inline delete-confirm row — replaces the trade row when the user
    clicks delete. Cancel link reverts to the trade row via a normal
    navigation back to /trades; confirm button submits DELETE /trades/:id.
    Avoids the JS confirm() dialog, consistent with Stockerly-2.0 patterns.
    es-MX per S11 #145. %>
<tr id="<%= dom_id(trade) %>" class="bg-negative-bg/40 border-y border-negative/30">
  <td colspan="8" class="px-6 py-4">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-4">
      <span class="material-symbols-outlined text-negative">delete</span>
      <div class="min-w-0 flex-1">
        <p class="text-sm font-semibold text-fg-default">¿Eliminar este movimiento permanentemente?</p>
        <p class="mt-1 text-xs text-fg-subtle">
          <%= trade.buy? ? "Compra" : "Venta" %> ·
          <span class="font-mono font-semibold text-fg-default"><%= trade.asset.symbol %></span> ·
          <%= trade.shares %> @ <%= format_currency_mx(trade.price_per_share, currency: trade.currency, precision: 4) %> ·
          <%= trade.executed_at.strftime("%d %b %Y %H:%M") %>
        </p>
      </div>
      <div class="flex items-center gap-2">
        <%= link_to trades_path,
              class: "rounded-lg border border-border-default bg-bg-surface px-3 py-1.5 text-xs font-medium text-fg-subtle hover:bg-bg-muted" do %>
          Cancelar
        <% end %>
        <%= button_to trade_path(trade), method: :delete,
              class: "inline-flex items-center gap-1.5 rounded-lg bg-negative px-3 py-1.5 text-xs font-bold text-white hover:opacity-90 transition-opacity cursor-pointer" do %>
          <span class="material-symbols-outlined text-[14px]">delete_forever</span>
          Sí, eliminar
        <% end %>
      </div>
    </div>
  </td>
</tr>
