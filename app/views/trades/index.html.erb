<%# Trades (Movimientos) — audit trail of all executed trades. es-MX per S09 #98. %>
<%# Summary aggregates by currency, scoped to the 50 most-recent trades
    shown in the table below. The aggregation lives in TradesHelper so the
    template stays focused on presentation. %>
<% summary = trades_summary_by_currency(@trades) %>
<% buys_by_currency  = summary[:buys] %>
<% sells_by_currency = summary[:sells] %>
<% fees_by_currency  = summary[:fees] %>

<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
  <div>
    <p class="text-[11px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">Tu portafolio</p>
    <h2 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white">Movimientos</h2>
    <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Historial auditable de tus operaciones. Edita o elimina movimientos recientes (≤30 días).</p>
  </div>
  <%= link_to portfolio_path, class: "px-4 py-2.5 border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-sm font-bold text-slate-700 dark:text-slate-300 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors shadow-sm" do %>
    <span class="material-symbols-outlined text-sm align-middle mr-1">arrow_back</span>
    Volver al portafolio
  <% end %>
</div>

<%# Summary cards — one row per currency present, grouped by buy/sell/fee %>
<% if @trades.present? %>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-5 shadow-sm">
      <p class="text-[11px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">Total compras</p>
      <div class="mt-2 space-y-1">
        <% if buys_by_currency.any? %>
          <% buys_by_currency.each do |currency, total| %>
            <p class="font-mono text-xl font-medium text-slate-900 dark:text-white"><%= format_currency_mx(total, currency: currency) %></p>
          <% end %>
        <% else %>
          <p class="font-mono text-xl font-medium text-slate-400">—</p>
        <% end %>
      </div>
    </div>

    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-5 shadow-sm">
      <p class="text-[11px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">Total ventas</p>
      <div class="mt-2 space-y-1">
        <% if sells_by_currency.any? %>
          <% sells_by_currency.each do |currency, total| %>
            <p class="font-mono text-xl font-medium text-slate-900 dark:text-white"><%= format_currency_mx(total, currency: currency) %></p>
          <% end %>
        <% else %>
          <p class="font-mono text-xl font-medium text-slate-400">—</p>
        <% end %>
      </div>
    </div>

    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-5 shadow-sm">
      <p class="text-[11px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">Comisiones</p>
      <div class="mt-2 space-y-1">
        <% if fees_by_currency.any? %>
          <% fees_by_currency.each do |currency, total| %>
            <p class="font-mono text-xl font-medium text-slate-900 dark:text-white"><%= format_currency_mx(total, currency: currency) %></p>
          <% end %>
        <% else %>
          <p class="font-mono text-xl font-medium text-slate-400">—</p>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<section class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 overflow-hidden shadow-sm">
  <% if @trades.present? %>
    <div class="overflow-x-auto">
      <table class="w-full text-left">
        <thead class="bg-slate-50 dark:bg-slate-800/50 text-xs uppercase tracking-wider text-slate-500">
          <tr>
            <th class="px-6 py-3 font-semibold">Fecha</th>
            <th class="px-6 py-3 font-semibold">Activo</th>
            <th class="px-6 py-3 font-semibold text-center">Operación</th>
            <th class="px-6 py-3 font-semibold text-right">Títulos</th>
            <th class="px-6 py-3 font-semibold text-right">Precio</th>
            <th class="px-6 py-3 font-semibold text-right">Total</th>
            <th class="px-6 py-3 font-semibold text-right">Comisión</th>
            <th class="px-6 py-3 font-semibold text-right">Acciones</th>
          </tr>
        </thead>
        <tbody id="trade_history" class="divide-y divide-slate-100 dark:divide-slate-800">
          <% @trades.each do |trade| %>
            <%= render "trades/trade_row", trade: trade %>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <%= render "components/empty_state", icon: "swap_horiz", title: "Aún no hay movimientos", description: "Tu historial de movimientos aparecerá aquí." %>
  <% end %>
</section>
