<%# Trade form — toggled inline. es-MX per S09 #91. %>
<div data-controller="reveal" class="mb-8">
  <button data-action="reveal#toggle"
      class="w-full bg-white dark:bg-slate-900 rounded-xl border-2 border-dashed border-slate-200 dark:border-slate-700 p-4 hover:border-primary transition-colors flex items-center justify-center gap-2 text-slate-500 hover:text-primary cursor-pointer">
    <span class="material-symbols-outlined text-xl">swap_horiz</span>
    <span class="text-sm font-semibold">Registrar movimiento</span>
  </button>

  <div data-reveal-target="content" class="hidden mt-4">
    <%= form_with(url: trades_path, scope: :trade, method: :post,
        class: "bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6 shadow-sm") do |f| %>

      <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-4">Nuevo movimiento</h3>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <%# Asset Symbol %>
        <div>
          <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Ticker</label>
          <%= f.text_field :asset_symbol, placeholder: "Ej. AAPL, ICA, BTC",
              class: "w-full px-3 py-2.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-sm text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-primary",
              required: true %>
        </div>

        <%# Side %>
        <div>
          <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Operación</label>
          <%= f.select :side, [["Compra", "buy"], ["Venta", "sell"]],
              {},
              class: "w-full px-3 py-2.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-sm text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-primary" %>
        </div>

        <%# Currency %>
        <div>
          <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Moneda <span class="text-slate-300">(opcional)</span></label>
          <%= f.select :currency, [["Auto (según activo)", ""], ["MXN", "MXN"], ["USD", "USD"]],
              {},
              class: "w-full px-3 py-2.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-sm text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-primary" %>
        </div>

        <%# Shares %>
        <div>
          <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Títulos</label>
          <%= f.number_field :shares, step: "any", min: "0.000001", placeholder: "0",
              class: "w-full px-3 py-2.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-sm text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-primary",
              required: true %>
        </div>

        <%# Price Per Share %>
        <div>
          <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Precio por título</label>
          <%= f.number_field :price_per_share, step: "any", min: "0.0001", placeholder: "0.00",
              class: "w-full px-3 py-2.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-sm text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-primary",
              required: true %>
        </div>

        <%# FX rate override (relevant when currency differs from asset's native currency) %>
        <div>
          <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Tipo de cambio <span class="text-slate-300">(opcional)</span></label>
          <%= f.number_field :fx_rate_at_execution, step: "any", min: "0", placeholder: "Auto (FIX Banxico)",
              class: "w-full px-3 py-2.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-sm text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-primary" %>
        </div>

        <%# Fee (optional) %>
        <div>
          <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Comisión <span class="text-slate-300">(opcional)</span></label>
          <%= f.number_field :fee, step: "any", min: "0", placeholder: "0.00",
              class: "w-full px-3 py-2.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-sm text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-primary" %>
        </div>

        <%# Executed At (optional, defaults to now) %>
        <div>
          <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Fecha de operación <span class="text-slate-300">(opcional)</span></label>
          <%= f.datetime_local_field :executed_at,
              class: "w-full px-3 py-2.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-sm text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-primary" %>
        </div>
      </div>

      <div class="mt-6 flex justify-end gap-3">
        <button type="button" data-action="reveal#toggle"
            class="px-4 py-2.5 border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-sm font-bold text-slate-700 dark:text-slate-300 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">
          Cancelar
        </button>
        <%= f.submit "Registrar movimiento",
            class: "px-6 py-2.5 bg-primary text-white text-sm font-bold rounded-lg hover:bg-primary/90 transition-colors shadow-sm cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
