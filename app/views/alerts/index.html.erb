<%# /alerts — manage alert rules + live feed. Lumen + es-MX, mockup Stockerly-2.0. %>

<div class="mx-auto max-w-6xl space-y-6">
  <%# Header band: eyebrow + h1 + subtitle + KPI mini-cards %>
  <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-slate-500 dark:text-slate-400">Alertas</p>
      <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white">Tus alertas</h1>
      <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Recibe avisos cuando algo importante pase con tus activos.</p>
    </div>
    <div class="flex gap-3">
      <div class="rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-5 py-3 shadow-sm min-w-[150px]">
        <p class="text-[10.5px] font-semibold uppercase tracking-[0.12em] text-slate-500 dark:text-slate-400">Disparadas hoy</p>
        <p class="mt-1 font-mono text-2xl font-medium tracking-tight text-slate-900 dark:text-white">
          <%= @triggered_today %>
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-5 py-3 shadow-sm min-w-[150px]">
        <p class="text-[10.5px] font-semibold uppercase tracking-[0.12em] text-slate-500 dark:text-slate-400">Reglas activas</p>
        <p class="mt-1 font-mono text-2xl font-medium tracking-tight text-slate-900 dark:text-white">
          <%= @counts[:active] %>
        </p>
      </div>
    </div>
  </div>

  <%# Main grid: 8/12 form + rules · 4/12 prefs + live feed %>
  <div class="grid grid-cols-1 gap-5 lg:grid-cols-12">
    <div class="space-y-5 lg:col-span-8 min-w-0">
      <%= render "alerts/create_form" %>
      <%= render "alerts/rules_table", rules: @rules, counts: @counts, filter: @filter %>
    </div>
    <div class="space-y-4 lg:col-span-4 min-w-0">
      <%= render "alerts/delivery_preferences", preference: @preference %>
      <%= render "alerts/live_feed", events: @events %>
    </div>
  </div>
</div>
