<%# Delivery preferences — toggle visuals only (no backend persistence yet). %>
<%# locals: (preference:) %>
<section class="rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-5 py-5 shadow-sm">
  <h2 class="text-base font-semibold tracking-tight text-slate-900 dark:text-white mb-3">Preferencias de entrega</h2>

  <%
    prefs = [
      { label: "Avisos en la app",            sub: "Push y campana del header",       checked: preference&.browser_push },
      { label: "Resumen diario por correo",   sub: "Un solo correo a las 18:30 CDMX", checked: preference&.email_digest },
      { label: "Avisos urgentes por correo",  sub: "Solo al disparar una regla",      checked: preference&.sms_notifications }
    ]
  %>
  <div class="flex flex-col">
    <% prefs.each_with_index do |pref, i| %>
      <div class="flex items-center gap-4 py-3 <%= 'border-t border-slate-200 dark:border-slate-700' if i.positive? %>" data-controller="toggle">
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-slate-900 dark:text-white"><%= pref[:label] %></p>
          <p class="mt-0.5 text-[11.5px] text-slate-500 dark:text-slate-400"><%= pref[:sub] %></p>
        </div>
        <button type="button" data-action="click->toggle#toggle"
                aria-label="<%= pref[:label] %>"
                class="relative inline-flex h-5 w-9 shrink-0 cursor-pointer items-center rounded-full transition-colors focus:outline-none">
          <span data-toggle-target="track" class="absolute inset-0 rounded-full transition-colors <%= pref[:checked] ? 'bg-primary' : 'bg-slate-200 dark:bg-slate-700' %>"></span>
          <span data-toggle-target="knob" class="relative inline-block h-4 w-4 rounded-full bg-white shadow transform transition-transform <%= pref[:checked] ? 'translate-x-5' : 'translate-x-0' %>"></span>
        </button>
      </div>
    <% end %>
  </div>

  <% if current_user&.email.present? %>
    <div class="mt-3 pt-3 border-t border-slate-200 dark:border-slate-700 flex items-center gap-2 text-xs text-slate-500 dark:text-slate-400">
      <span class="material-symbols-outlined text-[14px]">mail</span>
      <span>Configurado a tu correo:</span>
      <span class="font-mono font-medium text-slate-700 dark:text-slate-200"><%= current_user.email %></span>
      <span class="flex-1"></span>
      <%= link_to "Cambiar →", profile_path, class: "font-medium text-primary hover:underline" %>
    </div>
  <% end %>
</section>
