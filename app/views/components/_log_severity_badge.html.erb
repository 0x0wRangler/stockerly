<%# Usage: render "components/log_severity_badge", severity: "success" %>
<%# Supported: success, error, warning, info %>
<%# Severity names literally match the semantic tokens defined in @theme — #37. %>
<%
  config = {
    "success"  => { bg: "bg-success/10 dark:bg-success/20", text: "text-success", icon: "check_circle" },
    "error"    => { bg: "bg-error/10 dark:bg-error/20",     text: "text-error",   icon: "error" },
    "warning"  => { bg: "bg-warning/10 dark:bg-warning/20", text: "text-warning", icon: "warning" },
    "info"     => { bg: "bg-info/10 dark:bg-info/20",       text: "text-info",    icon: "info" }
  }
  c = config[severity.to_s] || config["info"]
%>
<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold <%= c[:bg] %> <%= c[:text] %>">
  <span class="material-symbols-outlined text-sm"><%= c[:icon] %></span>
  <%= severity.to_s.capitalize %>
</span>
