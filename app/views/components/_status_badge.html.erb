<%# Usage: render "components/status_badge", status: "active" %>
<%# Supported: active, paused, error, warning, info, pending, suspended, disabled, sync_issue %>
<%#
  Semantic tokens from app/assets/tailwind/application.css @theme (#37).
  Neutral states (pending, disabled) stay on slate because they describe
  absence rather than a success/warning/error event. Suspended and
  sync_issue collapse onto error/warning — they ARE those states under
  different domain names.
%>
<%
  colors = {
    "active"     => "bg-success/10 text-success-fg dark:bg-success/20 dark:text-success",
    "paused"     => "bg-warning/10 text-warning-fg dark:bg-warning/20 dark:text-warning",
    "error"      => "bg-error/10 text-error-fg dark:bg-error/20 dark:text-error",
    "warning"    => "bg-warning/10 text-warning-fg dark:bg-warning/20 dark:text-warning",
    "info"       => "bg-info/10 text-info-fg dark:bg-info/20 dark:text-info",
    "pending"    => "bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400",
    "suspended"  => "bg-error/10 text-error-fg dark:bg-error/20 dark:text-error",
    "disabled"   => "bg-slate-100 text-slate-500 dark:bg-slate-800 dark:text-slate-500",
    "sync_issue" => "bg-warning/10 text-warning-fg dark:bg-warning/20 dark:text-warning"
  }
  badge_class = colors[status.to_s] || colors["info"]
%>
<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold <%= badge_class %>">
  <%= status.to_s.capitalize %>
</span>
