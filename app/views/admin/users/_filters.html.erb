<%# Filter bar: search input + Rol chip group + Estado chip group %>
<%= form_with(url: admin_users_path, method: :get, data: { turbo_action: "replace", controller: "auto-submit" },
      class: "flex flex-wrap items-center gap-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-5 py-3 shadow-sm") do |f| %>

  <%# Search %>
  <div class="relative flex flex-1 min-w-[260px] items-center gap-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 px-3 h-9">
    <span class="material-symbols-outlined text-base text-slate-400">search</span>
    <%= f.text_field :search, value: params[:search],
        placeholder: "Buscar por nombre o correo…",
        autocomplete: "off",
        class: "w-full bg-transparent text-sm text-slate-900 dark:text-white placeholder-slate-400 outline-none" %>
  </div>

  <%# Hidden fields preserve the active chip selections when the search form
      submits — without these, typing a query would drop role/status. %>
  <%= hidden_field_tag :role, params[:role] if params[:role].present? %>
  <%= hidden_field_tag :status, params[:status] if params[:status].present? %>

  <div class="flex items-center gap-2.5">
    <span class="text-[10.5px] font-semibold uppercase tracking-[0.10em] text-slate-500 dark:text-slate-400">Rol</span>
    <div class="flex gap-1.5">
      <%
        roles = [
          [ "todos",    "Todos",   nil ],
          [ "user",     "Usuarios", "user" ],
          [ "admin",    "Admins",   "admin" ]
        ]
      %>
      <% roles.each do |slug, label, value| %>
        <% active = admin_users_filter_active?(:role, slug) %>
        <%= link_to admin_users_path(search: params[:search], status: params[:status], role: value),
              class: "inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-xs #{active ? 'font-semibold text-primary bg-primary/10 border border-primary/25' : 'font-medium text-slate-500 dark:text-slate-400 border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700/40'}" do %>
          <%= label %>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="h-5 w-px bg-slate-200 dark:bg-slate-700"></div>

  <div class="flex items-center gap-2.5">
    <span class="text-[10.5px] font-semibold uppercase tracking-[0.10em] text-slate-500 dark:text-slate-400">Estado</span>
    <div class="flex gap-1.5">
      <%
        statuses = [
          [ "todos",       "Todos",         nil ],
          [ "active",      "Activos",       "active" ],
          [ "suspended",   "Suspendidos",   "suspended" ],
          [ "unverified",  "Sin verificar", "unverified" ]
        ]
      %>
      <% statuses.each do |slug, label, value| %>
        <% active = admin_users_filter_active?(:status, slug) %>
        <%= link_to admin_users_path(search: params[:search], role: params[:role], status: value),
              class: "inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-xs #{active ? 'font-semibold text-primary bg-primary/10 border border-primary/25' : 'font-medium text-slate-500 dark:text-slate-400 border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700/40'}" do %>
          <%= label %>
        <% end %>
      <% end %>
    </div>
  </div>

  <% if params[:search].present? || params[:role].present? || params[:status].present? %>
    <div class="ml-auto">
      <%= link_to admin_users_path,
            class: "inline-flex items-center gap-1.5 text-xs font-medium text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200" do %>
        <span class="material-symbols-outlined text-[14px]">filter_alt_off</span>
        Limpiar filtros
      <% end %>
    </div>
  <% end %>
<% end %>
