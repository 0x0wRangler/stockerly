<%# Users table — dense rows, Lumen tokens, es-MX. %>
<%# Locals: users (collection), pagy (Pagy object) %>
<div class="overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 shadow-sm">
  <div class="overflow-x-auto">
    <table class="w-full text-left">
      <thead class="bg-slate-50 dark:bg-slate-900/40">
        <tr>
          <% %w[Perfil Registro Rol Estado].each do |h| %>
            <th class="px-4 py-3 text-[10.5px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400"><%= h %></th>
          <% end %>
          <th class="px-4 py-3 text-[10.5px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">Última actividad</th>
          <th class="px-4 py-3 text-right">
            <span class="sr-only">Acciones</span>
          </th>
        </tr>
      </thead>
      <tbody>
        <% if users.any? %>
          <% users.each do |user| %>
            <%= render "admin/users/user_row", user: user %>
          <% end %>
        <% else %>
          <tr>
            <td colspan="6" class="px-4 py-10 text-center text-sm text-slate-500 dark:text-slate-400">
              Sin usuarios que coincidan con los filtros.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if pagy.pages > 1 %>
    <div class="border-t border-slate-200 dark:border-slate-700 px-4 py-3">
      <%== pagy.series_nav %>
    </div>
  <% end %>
</div>
