<%# A single toggle row inside a settings card. Locals: name, label, description, on, applied_at, (first = false) %>
<% first ||= false %>
<div class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-4 py-4 <%= first ? "" : "border-t border-slate-200 dark:border-slate-700" %>">
  <div class="min-w-0">
    <div class="text-sm font-semibold tracking-tight text-slate-900 dark:text-white"><%= label %></div>
    <p class="mt-1 max-w-xl text-[12.5px] leading-relaxed text-slate-500 dark:text-slate-400"><%= description %></p>
    <% if applied_at.present? %>
      <p class="mt-1.5 font-mono text-[11px] tracking-[0.02em] text-slate-500 dark:text-slate-400">
        Aplicado <%= setting_applied_label(applied_at) %>
      </p>
    <% end %>
  </div>
  <label class="relative inline-flex shrink-0 cursor-pointer items-center">
    <input type="hidden" name="<%= name %>" value="0">
    <input type="checkbox" name="<%= name %>" value="1" class="peer sr-only" <%= "checked" if on %>>
    <div class="h-5 w-9 rounded-full bg-slate-300 dark:bg-slate-600 transition-colors peer-checked:bg-primary peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary/40 after:absolute after:left-0.5 after:top-0.5 after:size-4 after:rounded-full after:bg-white after:shadow-sm after:transition-all peer-checked:after:translate-x-4"></div>
  </label>
</div>
