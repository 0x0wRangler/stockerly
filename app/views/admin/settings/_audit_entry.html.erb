<%# A single audit-log entry: timestamp · admin cambió key: old → new. Locals: change, (first = false) %>
<% first ||= false %>
<div class="flex items-center gap-3 py-2.5 <%= first ? "" : "border-t border-slate-200 dark:border-slate-700" %>">
  <span class="whitespace-nowrap font-mono text-[11.5px] font-medium tracking-[0.02em] text-slate-500 dark:text-slate-400">
    <%= setting_absolute_ts(change.created_at) %>
  </span>
  <span class="min-w-0 flex-1 truncate text-[13px] text-slate-900 dark:text-white">
    <span class="font-mono font-semibold"><%= change.admin.full_name.split.first.downcase %></span>
    cambió
    <span class="font-mono text-slate-500 dark:text-slate-400"><%= setting_audit_key(change.key) %></span>:
    <span class="font-mono text-slate-500 dark:text-slate-400"><%= setting_audit_value(change.old_value) %></span>
    <span class="material-symbols-outlined align-middle text-[11px] text-slate-400">arrow_forward</span>
    <span class="font-mono font-semibold"><%= setting_audit_value(change.new_value) %></span>
  </span>
</div>
