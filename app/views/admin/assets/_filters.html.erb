<%# Filters: search input + Tipo / Estado / Mercado chip groups. %>
<%= form_with(url: admin_assets_path, method: :get, data: { turbo_action: "replace" },
      class: "flex flex-wrap items-center gap-4 rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-5 py-3 shadow-sm") do |f| %>
  <div class="flex flex-1 min-w-[260px] items-center gap-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 px-3 h-9">
    <span class="material-symbols-outlined text-base text-slate-400">search</span>
    <%= f.text_field :search, value: params[:search],
        placeholder: "Buscar por símbolo o nombre…",
        autocomplete: "off",
        class: "w-full bg-transparent text-sm text-slate-900 dark:text-white placeholder-slate-400 outline-none" %>
  </div>

  <%# Hidden fields preserve the active chip selections on search submit. %>
  <%= hidden_field_tag :type,   params[:type]   if params[:type].present? %>
  <%= hidden_field_tag :status, params[:status] if params[:status].present? %>
  <%= hidden_field_tag :market, params[:market] if params[:market].present? %>

  <div class="flex items-center gap-2.5">
    <span class="text-[10.5px] font-semibold uppercase tracking-[0.10em] text-slate-500 dark:text-slate-400">Tipo</span>
    <div class="flex flex-wrap gap-1.5">
      <%
        types = [
          [ "todos",        "Todos",       nil ],
          [ "stock",        "Acciones",    "stock" ],
          [ "etf",          "ETFs",        "etf" ],
          [ "crypto",       "Crypto",      "crypto" ],
          [ "fixed_income", "Renta fija",  "fixed_income" ],
          [ "index",        "Índices",     "index" ]
        ]
      %>
      <% types.each do |slug, label, value| %>
        <% active = admin_assets_filter_active?(:type, slug) %>
        <%= link_to admin_assets_path(search: params[:search], status: params[:status], market: params[:market], type: value),
              class: "inline-flex items-center rounded-full px-3 py-1.5 text-xs #{active ? 'font-semibold text-primary bg-primary/10 border border-primary/25' : 'font-medium text-slate-500 dark:text-slate-400 border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700/40'}" do %>
          <%= label %>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="h-5 w-px bg-slate-200 dark:bg-slate-700"></div>

  <div class="flex items-center gap-2.5">
    <span class="text-[10.5px] font-semibold uppercase tracking-[0.10em] text-slate-500 dark:text-slate-400">Estado</span>
    <div class="flex flex-wrap gap-1.5">
      <%
        statuses = [
          [ "todos",      "Todos",          nil ],
          [ "active",     "Activos",        "active" ],
          [ "disabled",   "Pausados",       "disabled" ],
          [ "sync_issue", "Con problemas",  "sync_issue" ]
        ]
      %>
      <% statuses.each do |slug, label, value| %>
        <% active = admin_assets_filter_active?(:status, slug) %>
        <%= link_to admin_assets_path(search: params[:search], type: params[:type], market: params[:market], status: value),
              class: "inline-flex items-center rounded-full px-3 py-1.5 text-xs #{active ? 'font-semibold text-primary bg-primary/10 border border-primary/25' : 'font-medium text-slate-500 dark:text-slate-400 border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700/40'}" do %>
          <%= label %>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="h-5 w-px bg-slate-200 dark:bg-slate-700"></div>

  <div class="flex items-center gap-2.5">
    <span class="text-[10.5px] font-semibold uppercase tracking-[0.10em] text-slate-500 dark:text-slate-400">Mercado</span>
    <div class="flex flex-wrap gap-1.5">
      <%
        markets = [
          [ "todos",   "Todos",   nil ],
          [ "BMV",     "BMV",     "BMV" ],
          [ "NASDAQ",  "NASDAQ",  "NASDAQ" ],
          [ "NYSE",    "NYSE",    "NYSE" ],
          [ "Banxico", "Banxico", "Banxico" ],
          [ "Otros",   "Otros",   "Otros" ]
        ]
      %>
      <% markets.each do |slug, label, value| %>
        <% active = admin_assets_filter_active?(:market, slug) %>
        <%= link_to admin_assets_path(search: params[:search], type: params[:type], status: params[:status], market: value),
              class: "inline-flex items-center rounded-full px-3 py-1.5 text-xs #{active ? 'font-semibold text-primary bg-primary/10 border border-primary/25' : 'font-medium text-slate-500 dark:text-slate-400 border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700/40'}" do %>
          <%= label %>
        <% end %>
      <% end %>
    </div>
  </div>

  <% if params[:search].present? || params[:type].present? || params[:status].present? || params[:market].present? %>
    <div class="ml-auto">
      <%= link_to admin_assets_path,
            class: "inline-flex items-center gap-1.5 text-xs font-medium text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200" do %>
        <span class="material-symbols-outlined text-[14px]">filter_alt_off</span>
        Limpiar filtros
      <% end %>
    </div>
  <% end %>
<% end %>
