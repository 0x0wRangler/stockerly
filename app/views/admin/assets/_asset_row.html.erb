<%# Single asset row + inline-edit form. Locals: asset, filter, failure_reasons %>
<%
  failure_reasons ||= {}
  status_key = admin_asset_status_key(asset)
  status_label = admin_asset_status_label(status_key)
  status_classes = admin_asset_status_pill_classes(status_key)
  last_sync_text, last_sync_classes = admin_asset_last_sync(asset)
  failure_reason = admin_asset_last_failure_reason(asset, failure_reasons)
%>
<tbody data-controller="reveal" class="border-t border-slate-100 dark:border-slate-800">
  <tr class="hover:bg-slate-50 dark:hover:bg-slate-900/40 transition-colors">
    <%# Activo: badge + name + symbol %>
    <td class="px-4 py-3">
      <div class="flex items-center gap-3 min-w-0">
        <%= render "components/asset_badge", asset: asset, size: "sm" %>
        <div class="min-w-0">
          <div class="truncate text-sm font-semibold text-slate-900 dark:text-white"><%= asset.name %></div>
          <div class="mt-0.5 font-mono text-[11px] font-medium tracking-wide text-slate-500 dark:text-slate-400"><%= asset.symbol %></div>
        </div>
      </div>
    </td>

    <%# Tipo %>
    <td class="px-4 py-3">
      <span class="inline-flex items-center rounded px-2 py-0.5 font-mono text-[11px] font-medium text-slate-500 dark:text-slate-400 bg-slate-100 dark:bg-slate-700">
        <%= admin_asset_type_label(asset) %>
      </span>
    </td>

    <%# Mercado %>
    <td class="px-4 py-3 whitespace-nowrap font-mono text-xs font-medium text-slate-700 dark:text-slate-200">
      <%= asset.exchange.presence || "—" %>
    </td>

    <%# País %>
    <td class="px-4 py-3 whitespace-nowrap font-mono text-xs text-slate-500 dark:text-slate-400">
      <%= asset.country.presence || "—" %>
    </td>

    <%# Última sync %>
    <td class="px-4 py-3 whitespace-nowrap">
      <span class="text-xs <%= last_sync_classes %>"><%= last_sync_text %></span>
    </td>

    <%# Estado %>
    <td class="px-4 py-3">
      <span title="<%= failure_reason ? "última falla: #{failure_reason[0]}" : "" %>"
            class="inline-flex items-center gap-1.5 rounded px-2 py-0.5 text-[11px] font-semibold uppercase tracking-wider <%= status_classes %> <%= 'cursor-help' if failure_reason %>">
        <span class="h-1.5 w-1.5 rounded-full bg-current"></span>
        <%= status_label %>
      </span>
    </td>

    <%# Acciones %>
    <td class="px-4 py-3 text-right">
      <div class="flex items-center justify-end gap-1.5">
        <%= button_to trigger_sync_admin_asset_path(asset), method: :post, params: filter,
              form: { class: "inline" },
              class: "inline-flex size-8 items-center justify-center rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-400 hover:text-emerald-600 dark:hover:text-emerald-400 hover:bg-slate-50 dark:hover:bg-slate-700/60",
              title: "Sincronizar ahora" do %>
          <span class="material-symbols-outlined text-base">sync</span>
        <% end %>

        <%= button_to toggle_status_admin_asset_path(asset), method: :patch, params: filter,
              form: { class: "inline" },
              class: "inline-flex size-8 items-center justify-center rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-700/60",
              title: asset.active? ? "Pausar" : "Reanudar" do %>
          <span class="material-symbols-outlined text-base"><%= asset.active? ? "pause" : "play_arrow" %></span>
        <% end %>

        <button type="button" data-action="reveal#toggle"
                class="inline-flex size-8 items-center justify-center rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-400 hover:text-primary hover:bg-slate-50 dark:hover:bg-slate-700/60 focus:outline-none focus:ring-2 focus:ring-primary/50"
                aria-label="Editar">
          <span class="material-symbols-outlined text-base">edit</span>
        </button>

        <%= button_to admin_asset_path(asset), method: :delete, params: filter,
              form: { class: "inline", data: { turbo_confirm: "Eliminar #{asset.symbol}? Esto borra watchlists, posiciones, trades e historial de precios." } },
              class: "inline-flex size-8 items-center justify-center rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-400 hover:text-rose-600 dark:hover:text-rose-400 hover:bg-slate-50 dark:hover:bg-slate-700/60",
              title: "Eliminar activo" do %>
          <span class="material-symbols-outlined text-base">delete</span>
        <% end %>
      </div>
    </td>
  </tr>

  <%# Inline edit row (hidden until edit clicked) %>
  <tr data-reveal-target="content" class="hidden bg-primary/5 dark:bg-primary/10">
    <td colspan="7" class="px-4 py-4">
      <%= form_with(url: admin_asset_path(asset, **filter), scope: :asset, method: :patch,
            class: "flex flex-wrap items-end gap-3") do |f| %>
        <%
          field_class = "rounded-lg border border-slate-300 dark:border-slate-600 bg-bg-surface px-2.5 py-1.5 text-sm text-slate-900 dark:text-white outline-none focus:ring-2 focus:ring-primary/40"
        %>
        <div class="flex flex-col gap-1">
          <label for="asset_name_<%= asset.id %>" class="text-[10px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">Nombre</label>
          <%= f.text_field :name, id: "asset_name_#{asset.id}", value: asset.name, placeholder: "Nombre", class: "#{field_class} w-56" %>
        </div>
        <div class="flex flex-col gap-1">
          <label for="asset_exchange_<%= asset.id %>" class="text-[10px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">Mercado</label>
          <%= f.text_field :exchange, id: "asset_exchange_#{asset.id}", value: asset.exchange, placeholder: "NASDAQ", class: "#{field_class} w-28 font-mono uppercase" %>
        </div>
        <div class="flex flex-col gap-1">
          <label for="asset_country_<%= asset.id %>" class="text-[10px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">País</label>
          <%= f.text_field :country, id: "asset_country_#{asset.id}", value: asset.country, placeholder: "XX", class: "#{field_class} w-16 font-mono uppercase" %>
        </div>
        <div class="flex flex-col gap-1">
          <label for="asset_sector_<%= asset.id %>" class="text-[10px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">Sector</label>
          <%= f.text_field :sector, id: "asset_sector_#{asset.id}", value: asset.sector, placeholder: "Sector", class: "#{field_class} w-32" %>
        </div>
        <div class="flex flex-1 flex-col gap-1 min-w-[200px]">
          <label for="asset_logo_url_<%= asset.id %>" class="text-[10px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">URL del logo</label>
          <%= f.text_field :logo_url, id: "asset_logo_url_#{asset.id}", value: asset.logo_url, placeholder: "https://…", class: "#{field_class} w-full font-mono text-xs" %>
        </div>
        <div class="ml-auto flex items-end gap-2 pt-1">
          <button type="button" data-action="reveal#toggle"
                  class="rounded-lg px-3 py-1.5 text-sm font-medium text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700/40">
            Cancelar
          </button>
          <%= f.submit "Guardar",
                class: "inline-flex items-center gap-1.5 rounded-lg bg-primary px-3 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-primary/90 cursor-pointer" %>
        </div>
      <% end %>
    </td>
  </tr>
</tbody>
