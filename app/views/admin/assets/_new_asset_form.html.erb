<%# New asset form — revealed by the header "Nuevo activo" CTA. %>
<div data-reveal-target="content" class="hidden">
  <%= form_with(url: admin_assets_path, scope: :asset, method: :post,
        class: "rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 p-5 shadow-sm space-y-4",
        data: { controller: "ticker-search", ticker_search_url_value: search_admin_assets_path }) do |f| %>

    <div class="flex items-start justify-between">
      <div>
        <h2 class="text-base font-semibold tracking-tight text-slate-900 dark:text-white">Nuevo activo</h2>
        <p class="mt-0.5 text-xs text-slate-500 dark:text-slate-400">Sembrar un activo en el catálogo del beta.</p>
      </div>
      <span class="text-[11px] text-slate-400 dark:text-slate-500">Una primera sincronización se programará al guardar.</span>
    </div>

    <%# Autocomplete search input %>
    <div class="relative">
      <div class="flex items-center gap-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 px-3 py-2 focus-within:ring-2 focus-within:ring-primary/40">
        <span class="material-symbols-outlined text-base text-slate-400">search</span>
        <input type="text"
               placeholder="Busca por símbolo o nombre (ej. AAPL, Apple)…"
               autocomplete="off"
               data-ticker-search-target="input"
               data-action="input->ticker-search#search keydown->ticker-search#navigate"
               class="w-full bg-transparent text-sm text-slate-900 dark:text-white placeholder-slate-400 outline-none" />
      </div>
      <div data-ticker-search-target="results"
           class="hidden absolute z-50 top-full left-0 right-0 mt-1 max-h-64 overflow-y-auto rounded-lg border border-slate-200 dark:border-slate-700 bg-bg-surface shadow-xl"></div>
    </div>

    <%
      input_class  = "w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 px-3 py-2 text-sm text-slate-900 dark:text-white placeholder-slate-400 outline-none focus:ring-2 focus:ring-primary/40"
      mono_class   = "#{input_class} font-mono uppercase tracking-wide"
      select_class = "w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 px-3 py-2 text-sm text-slate-700 dark:text-slate-200 outline-none focus:ring-2 focus:ring-primary/40"
    %>

    <div class="grid grid-cols-1 gap-3 md:grid-cols-2 lg:grid-cols-4">
      <div>
        <label for="asset_symbol" class="mb-1 block text-[10.5px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">Símbolo</label>
        <%= f.text_field :symbol, placeholder: "AAPL",
              data: { ticker_search_target: "symbol" }, class: mono_class %>
      </div>
      <div>
        <label for="asset_name" class="mb-1 block text-[10.5px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">Nombre</label>
        <%= f.text_field :name, placeholder: "Apple Inc.",
              data: { ticker_search_target: "name" }, class: input_class %>
      </div>
      <div>
        <label for="asset_asset_type" class="mb-1 block text-[10.5px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">Tipo</label>
        <%= f.select :asset_type,
              options_for_select([
                [ "Acción",    "stock" ],
                [ "ETF",       "etf" ],
                [ "Cripto",    "crypto" ],
                [ "Renta fija", "fixed_income" ],
                [ "Índice",    "index" ]
              ]),
              { prompt: "Selecciona…" },
              data: { ticker_search_target: "assetType" },
              class: select_class %>
      </div>
      <div>
        <label for="asset_exchange" class="mb-1 block text-[10.5px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">Mercado</label>
        <%= f.text_field :exchange, placeholder: "NASDAQ · BMV · COINGECKO",
              data: { ticker_search_target: "exchange" }, class: mono_class %>
      </div>
      <div>
        <label for="asset_country" class="mb-1 block text-[10.5px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">País</label>
        <%= f.text_field :country, placeholder: "MX · US",
              data: { ticker_search_target: "country" }, class: mono_class %>
      </div>
      <div>
        <label for="asset_sector" class="mb-1 block text-[10.5px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">Sector</label>
        <%= f.text_field :sector, placeholder: "Technology",
              data: { ticker_search_target: "sector" }, class: input_class %>
      </div>
      <div class="lg:col-span-2">
        <label for="asset_logo_url" class="mb-1 block text-[10.5px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">
          URL del logo
          <span class="ml-1 normal-case tracking-normal italic text-slate-400">opcional</span>
        </label>
        <%= f.text_field :logo_url, placeholder: "https://logos.stockerly.mx/…", class: "#{input_class} font-mono" %>
      </div>
    </div>

    <div class="flex items-center justify-end gap-2 border-t border-slate-200 dark:border-slate-700 pt-4">
      <button type="button" data-action="reveal#toggle"
              class="rounded-lg px-3 py-2 text-sm font-medium text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700/40">
        Cancelar
      </button>
      <%= f.submit "Crear activo",
            class: "inline-flex items-center gap-1.5 rounded-lg bg-primary px-3.5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-primary/90 cursor-pointer" %>
    </div>
  <% end %>
</div>
