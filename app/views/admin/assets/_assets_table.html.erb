<%# Assets catalogue table — Lumen tokens, es-MX, inline-edit per row. %>
<%# Locals: assets (collection), pagy (Pagy object), failure_reasons (Hash{symbol=>[message,ts]}) %>
<% filter = params.permit(:type, :status, :market, :search).to_h.compact_blank %>
<% failure_reasons ||= {} %>

<div class="overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 shadow-sm">
  <div class="overflow-x-auto">
    <table class="w-full text-left">
      <thead class="bg-slate-50 dark:bg-slate-900/40">
        <tr>
          <% %w[Activo Tipo Mercado País].each do |h| %>
            <th class="px-4 py-3 text-[10.5px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400"><%= h %></th>
          <% end %>
          <th class="px-4 py-3 text-[10.5px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">Última sync</th>
          <th class="px-4 py-3 text-[10.5px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">Estado</th>
          <th class="px-4 py-3 text-right">
            <span class="sr-only">Acciones</span>
          </th>
        </tr>
      </thead>
      <% if assets.any? %>
        <% assets.each do |asset| %>
          <%= render "admin/assets/asset_row", asset: asset, filter: filter, failure_reasons: failure_reasons %>
        <% end %>
      <% else %>
        <tbody>
          <tr>
            <td colspan="7" class="px-4 py-10 text-center text-sm text-slate-500 dark:text-slate-400">
              Sin activos que coincidan con los filtros.
            </td>
          </tr>
        </tbody>
      <% end %>
    </table>
  </div>

  <% if pagy.pages > 1 %>
    <div class="border-t border-slate-200 dark:border-slate-700 px-4 py-3">
      <%== pagy.series_nav %>
    </div>
  <% end %>
</div>
