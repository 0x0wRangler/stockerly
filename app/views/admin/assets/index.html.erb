<% content_for(:admin_page_title, "Activos") %>

<div class="space-y-6" data-controller="reveal">
  <%# Header band: eyebrow + h1 + subhead + CTAs %>
  <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-slate-500 dark:text-slate-400">Catálogo de activos</p>
      <h1 class="mt-2 text-2xl font-extrabold tracking-tight text-slate-900 dark:text-white">Activos</h1>
      <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Crea, edita y sincroniza activos rastreados por Stockerly.</p>
    </div>
    <div class="flex items-center gap-2">
      <%= button_to trigger_sync_all_admin_assets_path, method: :post,
            class: "inline-flex items-center gap-1.5 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-3.5 py-2 text-sm font-semibold text-slate-900 dark:text-white shadow-sm hover:bg-slate-50 dark:hover:bg-slate-700/60" do %>
        <span class="material-symbols-outlined text-[15px]">sync</span>
        Sincronizar todos
      <% end %>
      <button type="button" data-action="reveal#toggle"
              class="inline-flex items-center gap-1.5 rounded-lg bg-primary px-3.5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-primary/90">
        <span class="material-symbols-outlined text-[15px]">add</span>
        Nuevo activo
      </button>
    </div>
  </div>

  <% if @total_count.zero? %>
    <%= render "admin/assets/empty_state" %>
  <% else %>
    <%# Filter bar: search + Tipo + Estado + Mercado chip groups %>
    <%= render "admin/assets/filters" %>

    <%# New asset form (revealed by the Nuevo activo CTA above) %>
    <%= render "admin/assets/new_asset_form" %>

    <%# Assets table %>
    <%= render "admin/assets/assets_table", assets: @assets, pagy: @pagy, failure_reasons: @failure_reasons %>
  <% end %>
</div>
