<%# Asset price chart — SVG area chart using AssetPriceHistory data (30d).
    Used as fallback when TradingView isn't applicable (e.g. fixed income).
    Currency prefix in min/max badges matches the asset's native currency. %>
<% chart = price_chart_data(@price_histories) %>

<% if chart %>
  <% ccy = @asset.currency %>
  <section class="rounded-2xl border border-slate-200 dark:border-slate-700 bg-bg-surface p-5 shadow-sm">
    <div class="flex items-baseline justify-between mb-3">
      <div class="flex items-baseline gap-2">
        <h3 class="font-display text-base font-semibold tracking-tight text-slate-900 dark:text-white">
          <%= @asset.asset_type_fixed_income? ? "Tasa" : "Precio" %>
        </h3>
        <span class="text-xs text-slate-500 dark:text-slate-400">
          <%= ccy %> · últimos 30 días · cierre diario
        </span>
      </div>
      <div class="flex items-baseline gap-2 font-mono text-xs text-slate-500 dark:text-slate-400">
        <span><%= ccy %> <%= number_with_precision(chart[:min_price], precision: 2, delimiter: ',') %></span>
        <span class="text-slate-300 dark:text-slate-600">—</span>
        <span><%= ccy %> <%= number_with_precision(chart[:max_price], precision: 2, delimiter: ',') %></span>
      </div>
    </div>

    <div class="relative" data-controller="chart-tooltip">
      <svg viewBox="0 0 500 160" class="w-full h-40" preserveAspectRatio="none" data-chart-tooltip-target="svg">
        <line x1="0" y1="40"  x2="500" y2="40"  stroke="#e2e8f0" stroke-width="0.5" stroke-dasharray="4,4"/>
        <line x1="0" y1="80"  x2="500" y2="80"  stroke="#e2e8f0" stroke-width="0.5" stroke-dasharray="4,4"/>
        <line x1="0" y1="120" x2="500" y2="120" stroke="#e2e8f0" stroke-width="0.5" stroke-dasharray="4,4"/>

        <% if chart[:volume_bars].present? %>
          <% chart[:volume_bars].each do |bar| %>
            <rect x="<%= bar[:x] %>" y="<%= bar[:y] %>" width="<%= bar[:width] %>" height="<%= bar[:height] %>"
                  fill="<%= chart[:color] %>" opacity="0.15" rx="0.5"/>
          <% end %>
        <% end %>

        <polygon points="<%= chart[:area] %>" fill="<%= chart[:fill_color] %>" opacity="0.1"/>
        <polyline points="<%= chart[:points] %>" fill="none" stroke="<%= chart[:color] %>" stroke-width="2"
                  stroke-linejoin="round" stroke-linecap="round"/>

        <% chart[:data_points].each do |dp| %>
          <circle cx="<%= dp[:cx] %>" cy="<%= dp[:cy] %>" r="0"
                  fill="<%= chart[:color] %>" stroke="white" stroke-width="1.5"
                  data-date="<%= short_date_es(dp[:date]) %>"
                  data-value="<%= ccy %> <%= number_with_precision(dp[:value], precision: 2, delimiter: ',') %>"/>
        <% end %>
      </svg>

      <div data-chart-tooltip-target="tooltip"
           class="hidden absolute -top-8 text-[11px] font-medium text-slate-700 dark:text-slate-300 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded px-2 py-1 shadow-sm pointer-events-none whitespace-nowrap"></div>
    </div>

    <div class="flex justify-between mt-2 text-[10.5px] font-medium text-slate-500 dark:text-slate-400">
      <span><%= short_date_es(chart[:first_date], include_year: false) %></span>
      <span><%= short_date_es(chart[:last_date], include_year: false) %></span>
    </div>
  </section>
<% end %>
