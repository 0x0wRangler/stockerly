<%# Market Explorer — browse and filter trackable assets. es-MX per S09 #92. %>

<%# Header — kicker + title + descriptive subtitle %>
<div class="mb-6">
  <p class="text-[11px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">Explorar</p>
  <h2 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white">Mercados</h2>
  <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Índices, tipo de cambio, acciones, CETES y cripto en un solo lugar. Filtra y agrega a tu watchlist.</p>
</div>

<% if @indices.any? %>
  <%# Indices strip — MX-first per S09 #92 (IPC + IPC CompMx, then SPX/NDX/DJI/UKX) %>
  <div class="grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-5 gap-4 mb-4">
    <% @indices.each do |idx| %>
      <% change = idx.change_percent || 0 %>
      <%= render "components/index_card",
          name: idx.name,
          value: number_with_delimiter(idx.value.to_f, delimiter: ","),
          change_pct: "#{change >= 0 ? '+' : ''}#{number_with_precision(change, precision: 2)}%",
          direction: change >= 0 ? :up : :down,
          is_open: idx.is_open %>
    <% end %>
  </div>

  <%# VIX Volatility Indicator. Tier config (icons, colors, label) lives
      in MarketHelper#vix_tier for testability and reuse. %>
  <% if @vix %>
    <% vix_val = @vix.value.to_f %>
    <% tier = vix_tier(vix_val) %>
    <div class="flex items-center gap-4 bg-bg-surface rounded-xl border border-border-default px-5 py-3 mb-8 shadow-sm">
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-lg <%= tier[:icon] %>">speed</span>
        <span class="font-mono text-sm font-black text-slate-900 dark:text-white">VIX</span>
        <span class="font-mono text-sm font-bold <%= tier[:value] %>"><%= number_with_precision(vix_val, precision: 2) %></span>
      </div>
      <div class="flex-1 h-2 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
        <div class="h-full rounded-full bg-linear-to-r from-emerald-400 via-amber-400 to-rose-500" style="width: <%= [vix_val, 80].min / 80.0 * 100 %>%"></div>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <span class="text-xs font-semibold px-2 py-0.5 rounded-md <%= tier[:pill] %>"><%= tier[:label] %></span>
      </div>
    </div>
  <% end %>
<% end %>

<%# Search and Filters %>
<%= render "market/filters" %>

<%# Market Listings Table %>
<% if @assets.any? %>
  <%= render "market/listings_table", assets: @assets, pagy: @pagy, watchlisted_asset_ids: @watchlisted_asset_ids, market_status: @market_status %>
<% else %>
  <%= render "components/empty_state",
      icon: "search_off",
      title: "Sin resultados",
      description: "Ajusta los filtros o el término de búsqueda para encontrar activos.",
      cta_text: "Limpiar filtros",
      cta_path: market_path %>
<% end %>
