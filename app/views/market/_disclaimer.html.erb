<%# Regulatory disclaimer footer — es-MX (S10 #93). %>
<footer class="mt-auto pt-10 border-t border-slate-200 dark:border-slate-800">
  <div class="flex flex-col md:flex-row justify-between items-center gap-4 pb-2">
    <div class="flex items-center gap-2 text-primary/60">
      <span class="material-symbols-outlined text-lg">shield</span>
      <p class="text-xs font-medium text-slate-500 dark:text-slate-400">
        Información financiera con fines informativos. No constituye asesoría de inversión.
      </p>
    </div>
    <div class="flex gap-6">
      <%= link_to "Términos del servicio", terms_path, class: "text-[12px] font-medium text-slate-500 dark:text-slate-400 hover:text-primary transition-colors" %>
      <%= link_to "Aviso de privacidad", privacy_path, class: "text-[12px] font-medium text-slate-500 dark:text-slate-400 hover:text-primary transition-colors" %>
    </div>
  </div>
</footer>
