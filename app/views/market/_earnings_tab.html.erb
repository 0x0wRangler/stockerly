<%# Reportes trimestrales — historical EPS results, lazy-loaded into a
    turbo_frame. es-MX (S10 #93). Kept reachable via the lazy endpoint
    even though it's no longer surfaced as a tab on the show page. %>
<% if @earnings_events.present? %>
  <% reported = @earnings_events.select { |e| e.actual_eps.present? }.reverse %>
  <% if reported.size >= 2 %>
    <div class="mb-8">
      <h4 class="text-sm font-semibold text-slate-900 dark:text-white mb-4">Historial de EPS</h4>
      <div class="flex items-end gap-3 h-40">
        <% max_eps = reported.map { |e| [ e.actual_eps.to_f.abs, e.estimated_eps.to_f.abs ].max }.max %>
        <% max_eps = 1.0 if max_eps.zero? %>
        <% reported.each do |event| %>
          <div class="flex-1 flex flex-col items-center gap-1">
            <div class="w-full flex gap-0.5 items-end h-28">
              <% est_h = max_eps.positive? ? (event.estimated_eps.to_f.abs / max_eps * 100).round : 0 %>
              <div class="flex-1 bg-slate-200 dark:bg-slate-700 rounded-t" style="height: <%= est_h %>%" title="Estimado: <%= event.estimated_eps %>"></div>
              <% act_h = max_eps.positive? ? (event.actual_eps.to_f.abs / max_eps * 100).round : 0 %>
              <% beat = event.beat_miss == :beat %>
              <div class="flex-1 rounded-t <%= beat ? 'bg-emerald-500' : 'bg-rose-500' %>" style="height: <%= act_h %>%" title="Real: <%= event.actual_eps %>"></div>
            </div>
            <span class="text-[10px] text-slate-500 dark:text-slate-400"><%= event.report_date.strftime("%b %y") %></span>
          </div>
        <% end %>
      </div>
      <div class="flex items-center gap-4 mt-3">
        <div class="flex items-center gap-1.5">
          <span class="w-2.5 h-2.5 rounded-sm bg-slate-200 dark:bg-slate-700"></span>
          <span class="text-[10px] font-medium text-slate-500 dark:text-slate-400">Estimado</span>
        </div>
        <div class="flex items-center gap-1.5">
          <span class="w-2.5 h-2.5 rounded-sm bg-emerald-500"></span>
          <span class="text-[10px] font-medium text-slate-500 dark:text-slate-400">Superó</span>
        </div>
        <div class="flex items-center gap-1.5">
          <span class="w-2.5 h-2.5 rounded-sm bg-rose-500"></span>
          <span class="text-[10px] font-medium text-slate-500 dark:text-slate-400">Por debajo</span>
        </div>
      </div>
    </div>
  <% end %>

  <div class="overflow-x-auto rounded-xl border border-slate-200 dark:border-slate-700">
    <table class="w-full text-sm">
      <thead class="bg-slate-50 dark:bg-slate-800/40">
        <tr>
          <th class="text-left py-3 px-4 text-[11px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">Fecha del reporte</th>
          <th class="text-right py-3 px-4 text-[11px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">EPS estimado</th>
          <th class="text-right py-3 px-4 text-[11px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">EPS real</th>
          <th class="text-right py-3 px-4 text-[11px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">Sorpresa</th>
          <th class="text-center py-3 px-4 text-[11px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">Resultado</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
        <% @earnings_events.each do |event| %>
          <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30">
            <td class="py-3 px-4 text-slate-900 dark:text-white font-medium">
              <%= short_date_es(event.report_date) %>
              <span class="text-[10px] text-slate-500 dark:text-slate-400 ml-1">
                <%= event.before_market_open? ? "pre-apertura" : "cierre" %>
              </span>
            </td>
            <td class="py-3 px-4 text-right font-mono text-slate-600 dark:text-slate-300">
              <%= event.estimated_eps ? "#{event.asset.currency} #{number_with_precision(event.estimated_eps, precision: 2, delimiter: ',')}" : "—" %>
            </td>
            <td class="py-3 px-4 text-right font-mono font-semibold text-slate-900 dark:text-white">
              <%= event.actual_eps ? "#{event.asset.currency} #{number_with_precision(event.actual_eps, precision: 2, delimiter: ',')}" : "Por reportar" %>
            </td>
            <td class="py-3 px-4 text-right font-mono">
              <% if event.eps_surprise_percent %>
                <% positive = event.eps_surprise_percent >= 0 %>
                <span class="<%= positive ? 'text-emerald-600 dark:text-emerald-400' : 'text-rose-600 dark:text-rose-400' %> font-semibold">
                  <%= positive ? "+" : "" %><%= event.eps_surprise_percent %>%
                </span>
              <% else %>
                <span class="text-slate-400">—</span>
              <% end %>
            </td>
            <td class="py-3 px-4 text-center">
              <% case event.beat_miss %>
              <% when :beat %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-emerald-50 dark:bg-emerald-900/20 text-emerald-700 dark:text-emerald-400">
                  <span class="material-symbols-outlined text-xs">trending_up</span> Superó
                </span>
              <% when :miss %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-rose-50 dark:bg-rose-900/20 text-rose-700 dark:text-rose-400">
                  <span class="material-symbols-outlined text-xs">trending_down</span> Por debajo
                </span>
              <% else %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-amber-50 dark:bg-amber-900/20 text-amber-700 dark:text-amber-400">
                  <span class="material-symbols-outlined text-xs">schedule</span> Pendiente
                </span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="flex flex-col items-center justify-center py-12 text-center">
    <div class="mb-4 flex size-14 items-center justify-center rounded-2xl bg-slate-100 dark:bg-slate-800 text-slate-400">
      <span class="material-symbols-outlined text-3xl">event_note</span>
    </div>
    <h3 class="text-base font-semibold text-slate-900 dark:text-white">Sin reportes disponibles</h3>
    <p class="mt-1 max-w-md text-sm text-slate-500 dark:text-slate-400">
      Aún no tenemos histórico de reportes trimestrales para este activo.
    </p>
  </div>
<% end %>
