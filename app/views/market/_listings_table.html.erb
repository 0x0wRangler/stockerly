<%# Market listings table with real data from assets. es-MX per S09 #92. %>
<section class="rounded-xl border border-border-default bg-bg-surface overflow-hidden shadow-sm">
  <div class="flex items-center justify-between border-b border-slate-100 dark:border-slate-800 px-6 py-4">
    <h3 class="text-lg font-bold text-slate-900 dark:text-white">Listado de mercado</h3>
    <p class="text-sm text-slate-500 dark:text-slate-400"><span class="font-mono font-bold text-slate-900 dark:text-white"><%= pagy.count %></span> activos encontrados</p>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-left">
      <thead class="bg-slate-50 dark:bg-slate-800/50 text-xs uppercase tracking-wider text-slate-500">
        <tr>
          <th class="px-6 py-3 font-semibold">Activo / Ticker</th>
          <th class="px-6 py-3 font-semibold text-right">Precio</th>
          <th class="px-6 py-3 font-semibold text-right">Cambio (24h)</th>
          <th class="px-6 py-3 font-semibold text-center">Fuerza de tendencia</th>
          <th class="px-6 py-3 font-semibold text-center">7D</th>
          <th class="px-6 py-3 font-semibold text-center">Acción</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
        <% assets.each do |asset| %>
          <% change = asset.change_percent_24h || 0 %>
          <% positive = change >= 0 %>
          <% score = asset.latest_trend_score %>
          <% strength = score&.score || 0 %>
          <% strength_label = trend_strength_label(strength) %>
          <%= turbo_stream_from "asset_#{asset.id}" %>
          <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors cursor-pointer"
              data-controller="row-link" data-row-link-url-value="<%= market_asset_path(asset.symbol) %>"
              data-action="click->row-link#visit">
            <td class="px-6 py-4">
              <%= link_to market_asset_path(asset.symbol), class: "flex items-center gap-3 group" do %>
                <%= render "components/asset_badge", asset: asset, size: "sm", market_open: market_open_for(asset, market_status) %>
                <div>
                  <p class="text-sm font-bold text-slate-900 dark:text-white group-hover:text-primary transition-colors">
                    <% if asset.exchange.present? %>
                      <span class="font-mono text-slate-400 dark:text-slate-500 font-medium"><%= asset.exchange %></span>
                      <span class="text-slate-300 dark:text-slate-600 font-normal mx-0.5">:</span>
                    <% end %>
                    <span class="font-mono"><%= asset.symbol %></span>
                  </p>
                  <p class="text-xs text-slate-500"><%= asset.name %></p>
                </div>
              <% end %>
            </td>
            <td id="asset_price_<%= asset.id %>" class="px-6 py-4 text-right"
                data-controller="price-flash" data-price-flash-value="<%= asset.current_price %>">
              <span class="text-sm font-mono font-medium text-slate-900 dark:text-white"><%= format_currency_mx(asset.current_price, currency: asset.currency) %></span>
              <div class="mt-0.5"><%= render "components/data_status", asset: asset, market_open: market_open_for(asset, market_status) %></div>
            </td>
            <td class="px-6 py-4 text-right">
              <span class="inline-flex items-center rounded-lg px-2.5 py-1 text-xs font-mono font-bold <%= positive ? 'bg-success/10 dark:bg-success/20 text-success-fg dark:text-success' : 'bg-error/10 dark:bg-error/20 text-error-fg dark:text-error' %>">
                <%= positive ? '+' : '' %><%= number_with_precision(change, precision: 2) %>%
              </span>
            </td>
            <td class="px-6 py-4">
              <div class="flex flex-col items-center gap-1 relative"
                   data-controller="trend-breakdown"
                   data-action="mouseenter->trend-breakdown#show mouseleave->trend-breakdown#hide">
                <div class="w-full max-w-[80px] h-1.5 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                  <%# Three-bucket semantic map: strong → success, moderate → warning,
                      weak → error. Not a heatmap (no intermediate hues); reuses the
                      existing semantic tokens. %>
                  <% bar_color = if strength >= 80
                       'bg-success'
                     elsif strength >= 50
                       'bg-warning'
                     else
                       'bg-error'
                     end %>
                  <div class="h-full rounded-full <%= bar_color %>" style="width: <%= strength %>%"></div>
                </div>
                <span class="text-[10px] font-medium text-slate-500"><%= strength_label %> (<%= strength %>%)</span>
                <% if score&.factor_breakdown.present? %>
                  <div data-trend-breakdown-target="popover"
                       class="hidden absolute z-30 top-full mt-2 left-1/2 -translate-x-1/2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg shadow-lg p-3 w-48">
                    <p class="text-[10px] font-bold text-slate-500 uppercase mb-2">Factores</p>
                    <% breakdown = score.factor_breakdown %>
                    <% [ [ "RSI", breakdown[:rsi] ], [ "Momentum", breakdown[:momentum] ], [ "MACD", breakdown[:macd] ], [ "Volumen", breakdown[:volume_trend] ], [ "EMA Cross", breakdown[:ema_crossover] ] ].each do |name, value| %>
                      <% next unless value %>
                      <div class="flex items-center gap-2 mb-1.5">
                        <span class="text-[10px] text-slate-500 w-16 truncate"><%= name %></span>
                        <div class="flex-1 h-1 bg-slate-100 dark:bg-slate-700 rounded-full overflow-hidden">
                          <% fcolor = value >= 60 ? 'bg-success' : value >= 40 ? 'bg-warning' : 'bg-error' %>
                          <div class="h-full rounded-full <%= fcolor %>" style="width: <%= value.clamp(0, 100) %>%"></div>
                        </div>
                        <span class="text-[10px] font-mono font-medium text-slate-500 w-7 text-right"><%= value.round.to_i %></span>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </td>
            <td class="px-6 py-4">
              <div class="flex justify-center">
                <% real_heights = sparkline_heights(asset) %>
                <%= render "components/sparkline", direction: positive ? :up : :down, heights: real_heights %>
              </div>
            </td>
            <td class="px-6 py-4">
              <div class="flex items-center justify-center gap-2">
                <%= turbo_frame_tag "watchlist_button_#{asset.id}" do %>
                  <% if watchlisted_asset_ids.include?(asset.id) %>
                    <span class="inline-flex items-center gap-1 text-success-fg dark:text-success text-xs font-medium" title="En tu watchlist">
                      <span class="material-symbols-outlined text-lg">check_circle</span>
                    </span>
                  <% else %>
                    <%= button_to watchlist_items_path, params: { asset_id: asset.id }, class: "p-2 rounded-lg text-primary hover:bg-primary/10 transition-colors", title: "Agregar a watchlist" do %>
                      <span class="material-symbols-outlined text-lg">add_circle</span>
                    <% end %>
                  <% end %>
                <% end %>
                <span class="material-symbols-outlined text-slate-300 dark:text-slate-600 text-lg">chevron_right</span>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# Pagination %>
  <div class="border-t border-slate-100 dark:border-slate-800 px-6 py-4">
    <%== pagy.series_nav %>
  </div>
</section>
