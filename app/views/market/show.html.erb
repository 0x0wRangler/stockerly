<%# Asset detail — Stockerly-2.0 (S10 #93). Adaptive layout by asset type:
    - Equity / ETF: header → observations → chart → tabs (Resumen + optional
      Valoración / Dividendos / Estados financieros)
    - Crypto: header → observations → chart → tabs (Resumen + Mercado)
    - Fixed income (CETE): header → observations → yield card (replaces tabs)
    Tabs are skipped entirely when their underlying data is missing. %>
<%= turbo_stream_from "asset_#{@asset.id}" %>

<div class="mx-auto max-w-6xl space-y-6">
  <%= render "market/asset_header", asset: @asset, presenter: @presenter, is_watchlisted: @is_watchlisted %>

  <%= render "market/recent_observations", asset: @asset, observations: @recent_observations %>

  <% if @asset.asset_type_stock? || @asset.asset_type_etf? || @asset.asset_type_crypto? %>
    <%= render "market/tradingview_chart" %>
  <% else %>
    <%= render "market/price_chart" %>
  <% end %>

  <% if @asset.asset_type_fixed_income? %>
    <%# CETE / fixed income: yield card replaces the tab system %>
    <%= render "market/fixed_income_detail", asset: @asset, yield_data: @yield_data %>
  <% else %>
    <%
      tabs = asset_detail_tabs(
        @asset,
        has_fundamentals: @has_fundamentals,
        has_dividends:    @dividends.present?,
        has_statements:   @has_statements
      )
    %>

    <section class="rounded-2xl border border-slate-200 dark:border-slate-700 bg-bg-surface shadow-sm overflow-hidden" data-controller="tabs">
      <div class="border-b border-slate-200 dark:border-slate-800 overflow-x-auto">
        <div class="flex gap-1 min-w-max px-4">
          <%# Initial tab classes match what tabs_controller.js toggles
              (border-primary/border-transparent · text-primary/text-slate-400 ·
              font-bold/font-medium). The controller re-applies the active set
              on connect via showTab(0), so what we render here is just the
              first-paint state before Stimulus mounts. %>
          <% tabs.each_with_index do |tab, idx| %>
            <% active = idx.zero? %>
            <button data-tabs-target="tab" data-action="tabs#switch"
                    class="px-3.5 py-3 text-sm border-b-2 -mb-px transition-colors <%= active ? 'font-bold text-primary border-primary' : 'font-medium text-slate-400 border-transparent hover:text-slate-900 dark:hover:text-slate-100' %>">
              <%= tab[:label] %>
            </button>
          <% end %>
        </div>
      </div>

      <% tabs.each_with_index do |tab, idx| %>
        <div data-tabs-target="panel" class="<%= 'hidden' unless idx.zero? %> px-5 py-6">
          <% case tab[:key] %>
          <% when :resumen %>
            <%= render "market/summary_tab" %>
          <% when :valoracion %>
            <%= render "market/category_tab", category: :valuation %>
          <% when :mercado %>
            <%= render "market/category_tab", category: :crypto_market %>
          <% when :dividendos %>
            <%= render "market/dividend_history" %>
          <% when :estados %>
            <%= turbo_frame_tag "asset_statements_tab", src: market_asset_statements_tab_path(@asset.symbol), loading: "lazy" do %>
              <%= render "components/skeleton", type: "table_row", count: 5 %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </section>

    <%# P/E history shown below tabs for stocks only (visual evidence next to fundamentals) %>
    <%= render "market/pe_chart" if @asset.asset_type_stock? %>
  <% end %>

  <%= render "market/disclaimer" %>
</div>
