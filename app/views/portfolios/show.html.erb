<%# Portfolio — investment portfolio overview (Stockerly-2.0, S09 #91) %>

<%# Header — title + actions, always visible %>
<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
  <div>
    <p class="text-[11px] font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">Tu portafolio</p>
    <h2 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white">Posiciones y movimientos</h2>
    <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Registra tus operaciones, sigue tu desempeño y revisa tu distribución por tipo de activo.</p>
  </div>
  <div class="flex gap-3">
    <%= link_to trades_path, class: "px-4 py-2.5 border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-sm font-bold text-slate-700 dark:text-slate-300 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors shadow-sm" do %>
      <span class="material-symbols-outlined text-sm align-middle mr-1">history</span>
      Movimientos
    <% end %>
    <%= link_to market_path, class: "px-4 py-2.5 bg-primary text-white text-sm font-bold rounded-lg hover:bg-primary/90 transition-colors shadow-sm" do %>
      <span class="material-symbols-outlined text-sm align-middle mr-1">search</span>
      Explorar mercado
    <% end %>
  </div>
</div>

<%# 3 KPI cards — es-MX titles, MXN/USD ISO prefix, mono numbers %>
<% ug = @summary.unrealized_gain %>
<% dg = @summary.day_gain %>
<% bp_pct = @summary.total_value.positive? ? (@summary.buying_power / @summary.total_value * 100) : 0 %>
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
  <%= render "dashboard/kpi_card",
      icon:   "account_balance_wallet",
      title:  "Valor total del portafolio",
      value:  format_currency_mx(@summary.total_value, currency: @currency),
      change: { sign: dg.positive? ? "+" : "−", amount: number_with_precision(dg.percent.abs, precision: 2), label: "hoy", positive: dg.positive? } %>

  <%= render "dashboard/kpi_card",
      icon:    "trending_up",
      title:   "Ganancia no realizada",
      value:   "#{ug.positive? ? '+' : '−'} #{format_currency_mx(ug.absolute.abs, currency: @currency)}",
      tone:    (ug.positive? ? :positive : :default),
      change:  { sign: ug.positive? ? "+" : "−", amount: number_with_precision(ug.percent.abs, precision: 2), label: "", positive: ug.positive? },
      caption: @portfolio.inception_date.present? ? "Desde #{l(@portfolio.inception_date, format: '%d %b %Y')}" : nil %>

  <%= render "dashboard/kpi_card",
      icon:    "savings",
      title:   "Saldo disponible",
      value:   format_currency_mx(@summary.buying_power, currency: @currency),
      caption: "#{number_with_precision(bp_pct, precision: 1)}% del portafolio" %>
</div>

<%# Performance Chart %>
<%= render "portfolios/performance_chart",
    chart_data: @chart_data,
    period_returns: @period_returns,
    currency: @currency %>

<%# Trade Form — always visible %>
<%= render "trades/trade_form" %>

<%# Portfolio Grid: Allocation (1/3) + Positions (2/3) %>
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <%# Allocation Sidebar %>
  <%= render "portfolios/allocation_sidebar",
      allocation: @allocation,
      allocation_by_type: @allocation_by_type,
      summary: @summary %>

  <%# Positions Table %>
  <div class="lg:col-span-2">
    <%= render "portfolios/positions_table",
        tab: @tab,
        positions: @positions,
        portfolio: @portfolio,
        upcoming_dividends: @upcoming_dividends %>
  </div>
</div>
