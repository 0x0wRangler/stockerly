#!/usr/bin/env bash
set -euo pipefail

# Symlinks Claude Code's expected memory location to the in-repo .claude/memory/.
# Idempotent: safe to run on every container rebuild and on the host.
# Memory itself lives in .claude/memory/ and is tracked in git.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
REPO_MEMORY="$REPO_ROOT/.claude/memory"

# Claude derives project name by replacing / with - in the absolute workspace path.
PROJECT_NAME="$(echo "$REPO_ROOT" | sed 's|/|-|g')"
SYSTEM_DIR="$HOME/.claude/projects/$PROJECT_NAME"
SYSTEM_MEMORY="$SYSTEM_DIR/memory"

mkdir -p "$REPO_MEMORY" "$SYSTEM_DIR"

if [ -L "$SYSTEM_MEMORY" ]; then
  current="$(readlink "$SYSTEM_MEMORY")"
  if [ "$current" = "$REPO_MEMORY" ]; then
    echo "Claude memory symlink already correct: $SYSTEM_MEMORY -> $REPO_MEMORY"
    exit 0
  fi
  echo "Replacing existing symlink (was: $current)"
  rm "$SYSTEM_MEMORY"
elif [ -d "$SYSTEM_MEMORY" ]; then
  if [ -n "$(ls -A "$SYSTEM_MEMORY" 2>/dev/null)" ]; then
    BACKUP="$SYSTEM_MEMORY.backup.$(date +%s)"
    echo "Existing memory at $SYSTEM_MEMORY; backing up to $BACKUP"
    mv "$SYSTEM_MEMORY" "$BACKUP"
  else
    rmdir "$SYSTEM_MEMORY"
  fi
fi

ln -s "$REPO_MEMORY" "$SYSTEM_MEMORY"
echo "Claude memory linked: $SYSTEM_MEMORY -> $REPO_MEMORY"
